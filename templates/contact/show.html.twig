{% extends 'base.html.twig' %}

{% block title %}Voir contact - ORMada{% endblock %}

{% block body %}
    <div class="max-w-3xl">
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-4xl font-bold text-gray-800 mb-2 flex items-center gap-3">
                <span class="text-4xl">💬</span>
                {{ contact.nom }}
            </h1>
            <p class="text-gray-600">{{ contact.email }}</p>
        </div>

        <!-- Details Card -->
        <div class="bg-white rounded-xl shadow-lg p-8 border-l-4 border-purple-500 mb-8">
            <div class="space-y-6">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Identifiant</label>
                    <div class="px-4 py-3 bg-gray-50 rounded-lg border border-gray-200 text-gray-800 font-mono">
                        {{ contact.id }}
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Nom</label>
                    <div class="px-4 py-3 bg-gray-50 rounded-lg border border-gray-200 text-gray-800">
                        {{ contact.nom }}
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Email</label>
                    <div class="px-4 py-3 bg-gray-50 rounded-lg border border-gray-200 text-gray-800">
                        <a href="mailto:{{ contact.email }}" class="text-purple-600 hover:text-purple-700 underline">
                            {{ contact.email }}
                        </a>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Titre</label>
                    <div class="px-4 py-3 bg-gray-50 rounded-lg border border-gray-200 text-gray-800">
                        {{ contact.titre }}
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Description</label>
                    <div class="px-4 py-3 bg-gray-50 rounded-lg border border-gray-200 text-gray-800 whitespace-pre-wrap break-words">
                        {{ contact.description }}
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Créé le</label>
                        <div class="px-4 py-3 bg-gray-50 rounded-lg border border-gray-200 text-gray-800">
                            {{ contact.creerle ? contact.creerle|date('d/m/Y \u00e0 H:i') : 'Non spécifié' }}
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Statut de lecture</label>
                        <div class="px-4 py-3 bg-gray-50 rounded-lg border border-gray-200">
                            {% if contact.dejalu %}
                                <span class="inline-block px-3 py-1 bg-blue-100 text-blue-800 font-semibold rounded-full text-sm">
                                    ✓ Lu
                                </span>
                            {% else %}
                                <span class="inline-block px-3 py-1 bg-yellow-100 text-yellow-800 font-semibold rounded-full text-sm">
                                    ◎ Non lu
                                </span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="flex gap-3 flex-wrap">
            <a href="{{ path('app_contact_edit', {'id': contact.id}) }}" class="inline-flex items-center gap-2 px-6 py-3 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-lg transition-colors duration-200 shadow-md">
                <span>✏️</span>
                <span>Modifier</span>
            </a>
            
            <a href="{{ path('app_contact_index') }}" class="inline-flex items-center gap-2 px-6 py-3 bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold rounded-lg transition-colors duration-200">
                <span>←</span>
                <span>Retour à la liste</span>
            </a>
        </div>

        <!-- Delete Section -->
        <div class="mt-8 pt-8 border-t border-gray-200">
            {{ include('contact/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
