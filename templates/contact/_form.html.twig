{% set form_action = form_action ?? (form.vars.data.id ? path('app_contact_edit', {id: form.vars.data.id}) : path('app_interfacevisiteur')) %}

{{ form_start(form, {
    'action': form_action,
    'method': 'POST',
    'attr': {
        'class': 'space-y-6', 
        'novalidate': 'novalidate', 
        'id': 'contactForm',
        'enctype': 'multipart/form-data'
    }}) }}

<!-- Champ NOM -->
<div class="form-group">
    {{ form_label(form.nom, 'Nom', {
        'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}
    }) }}
    {{ form_widget(form.nom, {
        'attr': {
            'class': 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200',
            'placeholder': 'Votre nom'
        }
    }) }}
    {% if form.nom.vars.errors|length > 0 %}
        <div class="text-red-500 text-xs mt-1">
            {{ form_errors(form.nom) }}
        </div>
    {% endif %}
</div>

<!-- Champ EMAIL -->
<div class="form-group">
    {{ form_label(form.email, 'Email', {
        'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}
    }) }}
    {{ form_widget(form.email, {
        'attr': {
            'class': 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200',
            'placeholder': 'votre.email@example.com'
        }
    }) }}
    {% if form.email.vars.errors|length > 0 %}
        <div class="text-red-500 text-xs mt-1">
            {{ form_errors(form.email) }}
        </div>
    {% endif %}
</div>

<!-- Champ TITRE -->
<div class="form-group">
    {{ form_label(form.titre, 'Titre/Sujet', {
        'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}
    }) }}
    {{ form_widget(form.titre, {
        'attr': {
            'class': 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200',
            'placeholder': 'Sujet de votre message'
        }
    }) }}
    {% if form.titre.vars.errors|length > 0 %}
        <div class="text-red-500 text-xs mt-1">
            {{ form_errors(form.titre) }}
        </div>
    {% endif %}
</div>

<!-- Champ DESCRIPTION -->
<div class="form-group">
    {{ form_label(form.description, 'Message', {
        'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}
    }) }}
    {{ form_widget(form.description, {
        'attr': {
            'class': 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200',
            'placeholder': 'Votre message',
            'rows': '4'
        }
    }) }}
    {% if form.description.vars.errors|length > 0 %}
        <div class="text-red-500 text-xs mt-1">
            {{ form_errors(form.description) }}
        </div>
    {% endif %}
</div>

<!-- BOUTONS -->
<div class="flex justify-between pt-6 border-t gap-3">
    <button type="button"
       onclick="closeModal()"
       class="text-gray-600 hover:text-gray-900 text-sm px-5 py-2 rounded-md border border-gray-300 hover:bg-gray-100 transition">
        ← Annuler
    </button>

    <button type="submit"
        class="bg-green-600 hover:bg-green-700 text-white text-sm px-5 py-2 rounded-md transition">
        {{ button_label|default('Envoyer') }}
    </button>
</div>

{{ form_end(form) }}