{% extends 'base.html.twig' %}

{% block title %}Créer un nouveau contact - ORMada{% endblock %}

{% block body %}
    <div class="max-w-2xl ">
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-4xl font-bold text-gray-800 mb-2 flex items-center gap-3">
                <span class="text-4xl">💬</span>
                Créer un nouveau contact
            </h1>
            <p class="text-gray-600">Ajoutez une nouvelle entrée de contact</p>
        </div>

        <!-- Form Card -->
        <div class="bg-white rounded-xl shadow-lg p-8 border-l-4 border-purple-500">
            {{ include('contact/_form.html.twig') }}
        </div>

        <!-- Back Button -->
        <div class="mt-6">
            <a href="{{ path('app_contact_index') }}" class="inline-flex items-center gap-2 px-4 py-2 text-purple-600 hover:text-purple-700 hover:bg-purple-50 rounded-lg transition-colors duration-200">
                <span>←</span>
                <span>Retour à la liste</span>
            </a>
        </div>
    </div>
{% endblock %}
