{% extends 'base.html.twig' %}

{% block title %}Créer un nouveau paramètre - ORMada{% endblock %}

{% block body %}
    <div class="max-w-2xl">
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-4xl font-bold text-gray-800 mb-2 flex items-center gap-3">
                <span class="text-4xl">⚙️</span>
                Créer un nouveau paramètre
            </h1>
            <p class="text-gray-600">Ajoutez une nouvelle configuration au système</p>
        </div>

        <!-- Form Card -->
        <div class="bg-white rounded-xl shadow-lg p-8 border-l-4 border-teal-500">
            {{ include('parametre/_form.html.twig') }}
        </div>

        <!-- Back Button -->
        <div class="mt-6">
            <a href="{{ path('app_parametre_index') }}" class="inline-flex items-center gap-2 px-4 py-2 text-teal-600 hover:text-teal-700 hover:bg-teal-50 rounded-lg transition-colors duration-200">
                <span>←</span>
                <span>Retour à la liste</span>
            </a>
        </div>
    </div>
{% endblock %}
