{% extends 'base.html.twig' %}

{% block title %}Créer un Événement - ORMada{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto h-[80vh] flex flex-col pb-3">

    <!-- Header -->
    <div class="mb-3">
        <h1 class="text-3xl font-bold text-gray-700 mb-1">
            📅 Nouvel Événement
        </h1>
        <p class="text-gray-500 text-sm">
            Créez et organisez vos événements pour les visiteurs
        </p>
    </div>

    <!-- Card -->
    <div class="bg-white rounded-2xl shadow-xl border border-green-100 flex flex-col flex-1">

        <!-- Card Header -->
        <div class="bg-gradient-to-r from-green-600 to-emerald-600 px-6 py-2">
            <h2 class="text-white font-semibold text-lg">
                Informations de l'événement
            </h2>
        </div>

        <!-- Form Content (sans scroll) -->
        <div class="p-4 flex-1 text-sm">

            {# On applique un style compact au formulaire #}
            <div class="space-y-3">

                {{ include('evenement/_form.html.twig') }}

            </div>

        </div>

        <!-- Footer -->
        <div class="bg-gray-50 border-t border-gray-200 px-5 py-2 flex items-center justify-between text-xs">

           

            <p class="text-gray-400">
                Les champs * sont obligatoires
            </p>

        </div>

    </div>

</div>
{% endblock %}