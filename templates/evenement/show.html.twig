{% extends 'base.html.twig' %}

{% block title %}{{ evenement.titre }} - ORMada{% endblock %}

{% block body %}
    <div class="max-w-5xl mx-auto h-[50vh] px-4">
        {# <!-- Breadcrumb Navigation -->
        <div class="flex items-center gap-2 mb-8 text-sm">
            <a href="{{ path('app_evenement_index') }}" class="text-blue-600 hover:text-blue-700 font-medium">📅 Événements</a>
            <span class="text-gray-400">›</span>
            <span class="text-gray-600">{{ evenement.titre }}</span>
        </div> #}

        <!-- Header Section -->
        <div class="mb-12">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6 mb-8">
                <div class="flex items-start gap-6">
                    <div class="w-20 h-20 bg-gradient-to-br from-blue-400 to-indigo-600 rounded-2xl flex items-center justify-center text-4xl shadow-lg flex-shrink-0">📅</div>
                    <div>
                        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-3">{{ evenement.titre }}</h1>
                        <div class="flex flex-wrap gap-4">
                            {% if evenement.datedudebut %}
                                <div class="flex items-center gap-2 text-gray-600 bg-blue-50 px-4 py-2 rounded-lg border border-blue-200">
                                    <span class="text-lg">📆</span>
                                    <span class="font-semibold">Début:</span>
                                    <span>{{ evenement.datedudebut|date('d/m/Y') }}</span>
                                </div>
                            {% endif %}
                            {% if evenement.datedufin %}
                                <div class="flex items-center gap-2 text-gray-600 bg-purple-50 px-4 py-2 rounded-lg border border-purple-200">
                                    <span class="text-lg">🏁</span>
                                    <span class="font-semibold">Fin:</span>
                                    <span>{{ evenement.datedufin|date('d/m/Y') }}</span>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
                
                <!-- Action Buttons -->
                <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
                    <a href="{{ path('app_evenement_edit', {'id': evenement.id}) }}" class="group flex items-center justify-center gap-2 bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-600 hover:to-orange-600 text-white font-bold py-3 px-6 rounded-lg shadow-lg hover:shadow-xl transition-all transform hover:scale-105 active:scale-95">
                        <span class="text-lg">✏️</span>
                        <span>Modifier</span>
                    </a>
                    <a href="{{ path('app_evenement_index') }}" class="group flex items-center justify-center gap-2 text-gray-700 bg-gray-100 hover:bg-gray-200 font-bold py-3 px-6 rounded-lg transition-all">
                        <span class="text-lg">←</span>
                        <span>Retour</span>
                    </a>
                </div>
            </div>
        </div>

        <!-- Main Content Card -->
        <div class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-blue-100 mb-8">
            <!-- Decorative top bar -->
            <div class="h-1 bg-gradient-to-r from-blue-400 via-indigo-500 to-purple-600"></div>
            
            <!-- Description Section -->
            <div class="p-8 md:p-12 border-b border-gray-200">
                <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
                    <span class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center">📝</span>
                    Description
                </h2>
                <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed">
                    {{ evenement.description|nl2br }}
                </div>
            </div>

            <!-- Details Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-8 md:p-12 border-b border-gray-200">
                <!-- Dates Card -->
                <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl p-6 border border-blue-200">
                    <h3 class="text-lg font-bold text-gray-900 mb-6 flex items-center gap-2">
                        <span class="text-2xl">🗓️</span>
                        Dates
                    </h3>
                    <div class="space-y-4">
                        {% if evenement.datedudebut %}
                            <div class="flex justify-between items-center">
                                <span class="text-gray-600 font-semibold">Date de début:</span>
                                <span class="bg-white px-4 py-2 rounded-lg font-bold text-blue-600 border border-blue-200">{{ evenement.datedudebut|date('d/m/Y') }}</span>
                            </div>
                        {% endif %}
                        {% if evenement.datedufin %}
                            <div class="flex justify-between items-center">
                                <span class="text-gray-600 font-semibold">Date de fin:</span>
                                <span class="bg-white px-4 py-2 rounded-lg font-bold text-purple-600 border border-purple-200">{{ evenement.datedufin|date('d/m/Y') }}</span>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <!-- Info Card -->
                <div class="bg-gradient-to-br from-indigo-50 to-purple-50 rounded-2xl p-6 border border-indigo-200">
                    <h3 class="text-lg font-bold text-gray-900 mb-6 flex items-center gap-2">
                        <span class="text-2xl">ℹ️</span>
                        Informations
                    </h3>
                    <div class="space-y-4">
                        <div class="flex justify-between items-center">
                            <span class="text-gray-600 font-semibold">ID:</span>
                            <span class="bg-white px-4 py-2 rounded-lg font-mono text-gray-700 border border-gray-200">#{{ evenement.id }}</span>
                        </div>
                        <div>
                            <span class="text-gray-600 font-semibold block mb-2">Statut:</span>
                            {% if evenement.datedufin > "now" %}
                                <span class="inline-block bg-green-100 text-green-800 px-4 py-2 rounded-full text-sm font-bold border border-green-300">🟢 En cours</span>
                            {% else %}
                                <span class="inline-block bg-gray-100 text-gray-800 px-4 py-2 rounded-full text-sm font-bold border border-gray-300">⚪ Terminé</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Actions Footer -->
            <div class="bg-gradient-to-r from-gray-50 to-blue-50 border-t border-gray-200 px-8 md:px-12 py-8 flex flex-col sm:flex-row items-end justify-between gap-6">
                <p class="text-sm text-gray-600">
                    <span class="font-semibold">Créé/Modifié:</span> 
                    <span class="text-blue-600">À jour</span>
                </p>
                
                {{ include('evenement/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
