<form method="post" action="{{ path('app_evenement_delete', {'id': evenement.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ evenement.id) }}">
    <button type="submit" class="flex items-center justify-center gap-2 bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-5 rounded-xl shadow-md hover:shadow-lg transition-all transform hover:scale-105 active:scale-95">
        🗑️ Supprimer
    </button>
</form>