{% extends 'base.html.twig' %}

{% block title %}Événements - ORMada{% endblock %}

{% block body %}
    <div class="h-screen overflow-hidden bg-gradient-to-br from-slate-100 via-emerald-50 to-white flex flex-col">

    <!-- HEADER -->
    <section class="shrink-0 bg-gradient-to-r from-emerald-800 via-emerald-700 to-emerald-600 shadow-2xl">

        <div class="max-w-7xl mx-auto px-6 py-4 flex flex-col md:flex-row md:items-center md:justify-between gap-2">

            <div>

                <h1 class="text-4xl font-bold text-white">
                    Gestion des événements
                </h1>

                <p class="text-emerald-100 mt-2 text-sm tracking-wide">
                    Administration ORMada
                </p>

            </div>

            <form method="get"
                class=" p-5">

                <div class="flex gap-2 items-end">

                    <!-- RECHERCHE -->
                    <div class="flex-1 ">

                        <label class="block text-sm text-white font-semibold text-gray-700 mb-2">
                            Recherche
                        </label>

                        <input
                            type="text"
                            name="search"
                            placeholder="Titre ou description..."
                            class="w-full px-2 py-2
                                rounded-2xl
                                border border-gray-200
                                bg-gray-50
                                text-sm text-gray-700
                                placeholder-gray-400
                                focus:bg-white
                                focus:ring-2 focus:ring-emerald-500
                                focus:border-emerald-500
                                focus:outline-none
                                transition duration-300"
                        >

                    </div>

                    <!-- DATE DEBUT -->
                    <div class=" w-17 lg:w-17">

                        <label class="block text-sm text-white font-semibold text-gray-700 mb-2">
                            Date début
                        </label>

                        <input
                            type="date"
                            name="date_debut"
                            class="w-17 px-2 py-2
                                rounded-2xl
                                border border-gray-200
                                bg-gray-50
                                text-sm text-gray-700
                                focus:bg-white
                                focus:ring-2 focus:ring-emerald-500
                                focus:border-emerald-500
                                focus:outline-none
                                transition duration-300"
                        >

                    </div>

                    <!-- DATE FIN -->
                    <div class="w-17 lg:w-17">

                        <label class="block text-sm text-white font-semibold text-gray-700 mb-2">
                            Date fin
                        </label>

                        <input
                            type="date"
                            name="date_fin"
                            class="w-17 px-2 py-2
                                rounded-2xl
                                border border-gray-200
                                bg-gray-50
                                text-sm text-gray-700
                                focus:bg-white
                                focus:ring-2 focus:ring-emerald-500
                                focus:border-emerald-500
                                focus:outline-none
                                transition duration-300"
                        >

                    </div>

                    <!-- BUTTON -->
                    <div class="flex gap-3">

                        <button
                            type="submit"
                            class="px-2 py-3 rounded-2xl
                                bg-emerald-700 hover:bg-emerald-800
                                text-white text-sm font-semibold
                                shadow-md hover:shadow-xl
                                transition duration-300">

                            Rechercher

                        </button>

                    
                    </div>

                </div>

            </form>

            <a href="{{ path('app_evenement_new') }}"
               class="inline-flex items-center justify-center gap-1 px-6 py-2 bg-emerald-500 hover:bg-emerald-600 rounded-2xl  text-white font-semibold shadow-lg hover:shadow-2xl hover:-translate-y-1 transition duration-300">

                <span class="text-xl">+</span>
                <span>Créer un événement</span>

            </a>

        </div>

    </section>

        <!-- Table Section -->
        <div class="bg-white rounded-xl shadow-xl overflow-hidden border border-green-100 mt-3">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gradient-to-r from-green-800 via-emerald-700 to-teal-700 text-white">
                        <tr>
                            <th class="px-6 py-4 text-left font-semibold">ID</th>
                            <th class="px-6 py-4 text-left font-semibold">images</th>
                            <th class="px-6 py-4 text-left font-semibold">Titre</th>
                            <th class="px-6 py-4 text-left font-semibold">Description</th>
                            <th class="px-6 py-4 text-left font-semibold">Début</th>
                            <th class="px-6 py-4 text-left font-semibold">Fin</th>
                            <th class="px-6 py-4 text-left font-semibold">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-green-100">
                    {% for evenement in evenements %}
                        <tr class="hover:bg-green-50 transition-colors">
                            <td class="px-6 py-4 font-semibold text-gray-900">#{{ evenement.id }}</td>
                            <td class="px-2 py-2">
                                {% set image = evenement.media|first %}
                                {% if image %}
                                    <img src="{{ asset(image.chemindufichier) }}" alt="{{ evenement.titre }}" class="h-20 w-20 object-cover rounded">
                                {% else %}
                                    <img src="{{ asset('images/default.jpg') }}" alt="{{ evenement.titre }}" class="w-full h-28 object-cover rounded-lg">
                                {% endif %}
                            </td>
                            <td class="px-6 py-4"><span class="font-semibold text-gray-900">{{ evenement.titre }}</span></td>
                            <td class="px-6 py-4 text-gray-600 max-w-xs truncate">{{ evenement.description }}</td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center gap-2 bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm">
                                    📅 {{ evenement.datedudebut ? evenement.datedudebut|date('d/m/Y') : 'N/A' }}
                                </span>
                            </td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center gap-2 bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm">
                                    📅 {{ evenement.datedufin ? evenement.datedufin|date('d/m/Y') : 'N/A' }}
                                </span>
                            </td>
                            <td class="px-6 py-4 flex gap-3">
                                <a href="{{ path('app_evenement_show', {'id': evenement.id}) }}" class="text-green-600 hover:text-green-800 font-semibold hover:underline">👁️ Voir</a>
                                <a href="{{ path('app_evenement_edit', {'id': evenement.id}) }}" class="text-blue-600 hover:text-blue-800 font-semibold hover:underline">✏️ Éditer</a>
                                {{ include('evenement/_delete_form.html.twig') }}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="px-6 py-8 text-center text-gray-500">
                                <div class="text-6xl mb-4">📭</div>
                                <p class="text-lg font-semibold">Aucun événement trouvé</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
