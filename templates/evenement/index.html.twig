{% extends 'base.html.twig' %}

{% block title %}Événements - ORMada{% endblock %}

{% block body %}
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="mb-12">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h1 class="text-5xl font-bold text-gray-700 mb-2">📅 Événements</h1>
                    <p class="text-gray-600 text-md">Organisez vos événements de manière simple et efficace</p>
                </div>
                <a href="{{ path('app_evenement_new') }}" class="bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white font-bold py-3 px-8 rounded-lg shadow-lg hover:shadow-xl transition-all transform hover:scale-105">
                    ➕ Nouvel Événement
                </a>
            </div>
        </div>

        <!-- Table Section -->
        <div class="bg-white rounded-xl shadow-xl overflow-hidden border border-green-100">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gradient-to-r from-green-800 via-emerald-700 to-teal-700 text-white">
                        <tr>
                            <th class="px-6 py-4 text-left font-semibold">ID</th>
                            <th class="px-6 py-4 text-left font-semibold">images</th>
                            <th class="px-6 py-4 text-left font-semibold">Titre</th>
                            <th class="px-6 py-4 text-left font-semibold">Description</th>
                            <th class="px-6 py-4 text-left font-semibold">Début</th>
                            <th class="px-6 py-4 text-left font-semibold">Fin</th>
                            <th class="px-6 py-4 text-left font-semibold">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-green-100">
                    {% for evenement in evenements %}
                        <tr class="hover:bg-green-50 transition-colors">
                            <td class="px-6 py-4 font-semibold text-gray-900">#{{ evenement.id }}</td>
                            <td class="px-2 py-2">
                                {% set image = evenement.media|first %}
                                {% if image %}
                                    <img src="{{ asset(image.chemindufichier) }}" alt="{{ evenement.titre }}" class="w-full h-28 object-cover rounded-lg">
                                {% else %}
                                    <img src="{{ asset('images/default.jpg') }}" alt="{{ evenement.titre }}" class="w-full h-28 object-cover rounded-lg">
                                {% endif %}
                            </td>
                            <td class="px-6 py-4"><span class="font-semibold text-gray-900">{{ evenement.titre }}</span></td>
                            <td class="px-6 py-4 text-gray-600 max-w-xs truncate">{{ evenement.description }}</td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center gap-2 bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm">
                                    📅 {{ evenement.datedudebut ? evenement.datedudebut|date('d/m/Y') : 'N/A' }}
                                </span>
                            </td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center gap-2 bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm">
                                    📅 {{ evenement.datedufin ? evenement.datedufin|date('d/m/Y') : 'N/A' }}
                                </span>
                            </td>
                            <td class="px-6 py-4 flex gap-3">
                                <a href="{{ path('app_evenement_show', {'id': evenement.id}) }}" class="text-green-600 hover:text-green-800 font-semibold hover:underline">👁️ Voir</a>
                                <a href="{{ path('app_evenement_edit', {'id': evenement.id}) }}" class="text-blue-600 hover:text-blue-800 font-semibold hover:underline">✏️ Éditer</a>
                                {{ include('evenement/_delete_form.html.twig') }}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="px-6 py-8 text-center text-gray-500">
                                <div class="text-6xl mb-4">📭</div>
                                <p class="text-lg font-semibold">Aucun événement trouvé</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
