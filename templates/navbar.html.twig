<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="stylesheet" href="{{ asset('styles.css') }}">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
     <body class="bg-gradient-to-br from-green-50 via-emerald-50 to-teal-100 min-h-screen">

            <!-- Navbar à gauche -->
            <nav class="w-64 bg-gradient-to-r from-emerald-800 via-emerald-700 to-emerald-600 text-white shadow-4xl h-screen sticky top-0">
                <!-- Logo/Titre -->
                <div class="p-6 border-b border-green-700">
                    <h1 class="text-2xl font-bold flex items-center gap-2 text-white">
                        <span class="text-3xl">🌐</span>
                        <span>ORMada</span>
                    </h1>
                    <p class="text-xs text-green-200 mt-1">Site Web</p>
                </div>

                <!-- Menu Links -->
                <ul class="py-6 space-y-2 px-4">
                     <li>
                        <a href="{{ path('app_page_accueil') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-green-700 transition-colors duration-200 text-white {% if app.request.attributes.get('_route') == 'app_dashboard' %}bg-teal-500{% endif %}">
                            <span class="text-lg">🏠</span>
                            <span class="font-medium">Dashboard</span>
                        </a>
                    </li>
                   
                    <li>
                        <a href="{{ path('app_actualite_index') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-green-700 transition-colors duration-200 text-white {% if app.request.attributes.get('_route') == 'app_actualite_index' %}bg-teal-500{% endif %}">
                            <span class="text-lg">📰</span>
                            <span class="font-medium">Actualités</span>
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_evenement_index') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-green-700 transition-colors duration-200 text-white {% if app.request.attributes.get('_route') == 'app_evenement_index' %}bg-teal-500{% endif %}">
                            <span class="text-lg">📅</span>
                            <span class="font-medium">Événements</span>
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_contact_index') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-green-700 transition-colors duration-200 text-white {% if app.request.attributes.get('_route') == 'app_contact_index' %}bg-teal-500{% endif %}">
                            <span class="text-lg">💬</span>
                            <span class="font-medium">Avis des visiteurs</span>
                        </a>
                    </li>
                  
                    <li>
                        <a href="{{ path('app_media_index') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-green-700 transition-colors duration-200 text-white {% if app.request.attributes.get('_route') == 'app_media_index' %}bg-teal-500{% endif %}">
                            <span class="text-lg">🎬</span>
                            <span class="font-medium">Media</span>
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_user_index') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-green-700 transition-colors duration-200 text-white {% if app.request.attributes.get('_route') == 'app_user_index' %}bg-teal-500{% endif %}">
                            <span class="text-lg">👤</span>
                            <span class="font-medium">UserAdmin</span>
                        </a>
                    </li>
                </ul>

                <!-- Separator -->
                <div class="mx-4 my-4 border-t border-green-700"></div>

                <!-- Admin Section -->
                <div class="px-4 py-4">
                    <p class="text-xs font-semibold text-green-200 uppercase tracking-wide mb-3">Paramètres</p>
                    <a href="{{ path('app_parametre_index') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-green-700 transition-colors duration-200 text-white">
                        <span class="text-lg">⚙️</span>
                        <span class="font-medium text-sm">Configuration</span>
                    </a>
                </div>

               

                <!-- Footer Info -->
                <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-green-700 bg-green-800">
                    <p class="text-xs text-green-300 text-center">© 2026 ORMada</p>
                </div>

            </nav>

    </body>
    
</html>
