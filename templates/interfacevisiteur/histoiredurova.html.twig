<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Le Rova de Manjakamiadana - Histoire de Madagascar</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com" rel="stylesheet">
    <style>
        .hero-gradient { background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://upload.wikimedia.org'); background-size: cover; background-position: center; }
        .fade-in { opacity: 0; transform: translateY(20px); transition: all 0.8s ease-out; }
        .fade-in.visible { opacity: 1; transform: translateY(0); }
    </style>
</head>
<body class="bg-stone-50 text-stone-800 font-sans">

    <header class="fixed top-0 left-0 w-full bg-green-600 shadow-lg z-50">
    <div class="max-w-7xl mx-auto flex justify-between items-center px-4 md:px-6 py-3">
        {# Logo et nom #}
       <div class="flex items-center gap-2 md:gap-3">
            <img src="images/logo.jpg" 
                alt="Blason de Madagascar" 
                class="h-12 w-12 md:h-15 md:w-15 rounded-full object-cover">
            <span class="text-white font-bold text-lg md:text-xl">ORMada</span>
        </div>

        {# Navigation desktop #}
        <nav class="hidden md:flex gap-6 lg:gap-8 text-white font-semibold">
            <a href="{{ path('app_interfacevisiteur') }}#actualites" class="hover:text-yellow-300 transition duration-300">Actualité</a>
            <a href="{{ path('app_interfacevisiteur') }}#evenements" class="hover:text-yellow-300 transition duration-300">Événements</a>
            <a href="{{ path('app_interfacevisiteur') }}#informations" class="hover:text-yellow-300 transition duration-300">Infos</a>
            <a href="{{ path('app_interfacevisiteur') }}#apropos" class="hover:text-yellow-300 transition duration-300">À propos</a>
            <a href="{{ path('app_interfacevisiteur') }}#contacts" class="hover:text-yellow-300 transition duration-300">Contacts</a>
        </nav>
     

        {# Bouton menu mobile #}
        <button class="md:hidden text-white" onclick="toggleMobileMenu()" aria-label="Menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>
    </div>

    {# Menu mobile #}
    <div id="mobileMenu" class="hidden md:hidden bg-green-700 px-4 py-3">
        <nav class="flex flex-col gap-3 text-white font-semibold">
            <a href="{{ path('app_interfacevisiteur') }}#actualites" onclick="toggleMobileMenu()" class="py-2 hover:bg-green-600 px-3 rounded">Actualité</a>
            <a href="{{ path('app_interfacevisiteur') }}#evenements" onclick="toggleMobileMenu()" class="py-2 hover:bg-green-600 px-3 rounded">Événements</a>
            <a href="{{ path('app_interfacevisiteur') }}#informations" onclick="toggleMobileMenu()" class="py-2 hover:bg-green-600 px-3 rounded">Infos</a>
            <a href="{{ path('app_interfacevisiteur') }}#apropos" onclick="toggleMobileMenu()" class="py-2 hover:bg-green-600 px-3 rounded">À propos</a>
            <a href="{{ path('app_interfacevisiteur') }}#contacts"  onclick="toggleMobileMenu()" class="py-2 hover:bg-green-600 px-3 rounded">Contacts</a>
        </nav>
    </div>
</header>

    <!-- Hero Section -->
    <header class="h-[70vh] hero-gradient flex items-center justify-center text-center text-white px-4">
        <div class="max-w-3xl">
            <h2 class="text-5xl md:text-7xl font-serif mb-4">Manjakamiadana</h2>
            <p class="text-xl md:text-2xl font-light italic">"Où l'on règne dans la paix"</p>
            <div class="mt-8 h-1 w-24 bg-red-600 mx-auto"></div>
        </div>
    </header>

    <main class="max-w-5xl mx-auto px-6 py-16">
        
        <!-- Introduction -->
        <section class="mb-20 text-center fade-in">
            <p class="text-lg leading-relaxed text-stone-600 italic">
                Sur la plus haute colline d'Antananarivo, Analamanga, se dresse le Rova. Bien plus qu'un palais, c'est le cœur historique et spirituel du peuple malgache.
            </p>
        </section>

        <!-- Origines -->
        <section id="origine" class="mb-24 flex flex-col md:flex-row items-center gap-12 fade-in">
            <div class="md:w-1/2">
                <img src="{{ asset('images/rovaen1610.jpg') }}" alt="Entrée du Rova" class="rounded-lg shadow-xl object-cover h-80 w-full">
            </div>
            <div class="md:w-1/2">
                <h3 class="text-3xl font-serif text-red-900 mb-4">1610 : La Fondation</h3>
                <p class="mb-4">Tout commence avec le roi <strong>Andrianjaka</strong>. Il conquiert la colline et y installe le premier camp fortifié. C'est ici que naissent les fondations du royaume Merina.</p>
                <p class="text-stone-600">Le site servait à la fois de forteresse et de lieu de sépulture sacrée pour les rois.</p>
            </div>
        </section>

        <!-- L'Âge d'Or -->
        <section id="age-dor" class="mb-24 bg-white p-8 rounded-2xl shadow-sm border border-stone-100 fade-in">
            <h3 class="text-3xl font-serif text-red-900 mb-8 text-center">XIXe Siècle : La Splendeur</h3>
            <div class="grid md:grid-cols-2 gap-8">
                <div>
                    <h4 class="font-bold text-red-700 mb-2">Le Palais de Bois (1839)</h4>
                    <p class="text-sm leading-relaxed">Sous Ranavalona Ière, Jean Laborde érige un immense palais entièrement en bois précieux. Un pilier central unique de 39 mètres de haut soutenait l'édifice.</p>
                </div>
                <div>
                    <h4 class="font-bold text-red-700 mb-2">Le Manteau de Pierre (1867)</h4>
                    <p class="text-sm leading-relaxed">James Cameron, sous Ranavalona II, recouvre le bois de pierre pour le protéger, donnant au palais son aspect imposant de forteresse européenne.</p>
                </div>
            </div>
        </section>

        <!-- Le Drame -->
        <section id="incendie" class="mb-24 flex flex-col-reverse md:flex-row items-center gap-12 fade-in">
            <div class="md:w-1/2">
                <h3 class="text-3xl font-serif text-stone-900 mb-4">1995 : La Nuit de l'Incendie</h3>
                <p class="mb-4">Le 6 novembre 1995, le ciel d'Antananarivo rougit. Un incendie suspect ravage le palais. En quelques heures, les structures en bois et des siècles de trésors royaux partent en fumée.</p>
                <div class="bg-stone-200 p-4 border-l-4 border-red-600 italic">
                    "Un traumatisme national dont les cicatrices marquent encore les esprits."
                </div>
            </div>
            <div class="md:w-1/2">
                <img src="{{ asset('images/rovaenfeu.jpg') }}" alt="Symbolisme feu" class="rounded-lg shadow-xl brightness-50">
            </div>
        </section>

        <!-- Renaissance -->
        <section id="renaissance" class="text-center fade-in">
            <h3 class="text-3xl font-serif text-red-900 mb-6">Aujourd'hui : La Renaissance</h3>
            <p class="max-w-2xl mx-auto mb-8">Après 25 ans de silence, le Rova a été restauré. Désormais appelé "Rovan’ny Madagasikara", il accueille de nouveau les visiteurs, mêlant patrimoine historique et architecture moderne.</p>
            <a href="#" class="inline-block bg-red-800 text-white px-8 py-3 rounded-full hover:bg-red-900 transition">Visiter le site aujourd'hui</a>
        </section>

    </main>

    <footer class="bg-stone-900 text-stone-400 py-12 text-center">
        <p>© 2024 - Histoire du Rova d'Antananarivo</p>
        <div class="mt-4 flex justify-center space-x-4">
            <i class="fab fa-facebook hover:text-white cursor-pointer transition"></i>
            <i class="fab fa-instagram hover:text-white cursor-pointer transition"></i>
        </div>
    </footer>

    <script>
    // Gestion du menu mobile
        function toggleMobileMenu() {
            const menu = document.getElementById('mobileMenu');
            menu.classList.toggle('hidden');
        }
        // Animation au défilement (Scroll Reveal)
        const observerOptions = { threshold: 0.1 };
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, observerOptions);

        document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
    </script>
</body>
</html>