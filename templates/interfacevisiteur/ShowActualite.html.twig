<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ actualiteShow.titre }} - ORMada</title>

    <script src="https://cdn.tailwindcss.com"></script>


</head>

<body class="bg-gradient-to-b from-emerald-50 via-white to-white min-h-screen text-gray-800">

<!-- HEADER Navbar -->
{% include 'interfacevisiteur/NavbarInterfaceVisiteur.html.twig' %}

<!-- MAIN -->
<main class="max-w-5xl mx-auto px-4 py-10">

    <section class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-emerald-100">

        <!-- Bandeau -->
        <div class="h-2 bg-gradient-to-r from-emerald-800 via-emerald-700 to-grenat"></div>

        <!-- ==================== -->
        <!-- TITRE + INFOS -->
        <!-- ==================== -->
        <div class="p-8 md:p-10 border-b border-gray-100">

            <span class="inline-block bg-emerald-100 text-emerald-700 text-xs font-bold px-4 py-2 rounded-full mb-4">
                ACTUALITÉ
            </span>

            <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4 leading-tight">
                {{ actualiteShow.titre }}
            </h1>

            <div class="flex flex-col gap-3 text-gray-700">

                <div class="flex items-center gap-1">
                    <span>📅</span>
                    <span>
                        {% if actualiteShow.publierle %}
                            Publié le
                            <strong>{{ actualiteShow.publierle|date('d/m/Y à H:i') }}</strong>
                        {% else %}
                            Non publié
                        {% endif %}
                    </span>
                </div>


            </div>

        </div>

        <!-- CONTENU -->
        
        <div class="p-3 md:p-4 border-b border-gray-100">

            <div class="bg-gray-50 rounded-2xl border border-gray-100 p-3 md:p-3">

                <p class="text-gray-700 leading-8 whitespace-pre-line text-justify">
                    {{ actualiteShow.contenu }}
                </p>

            </div>

        </div>

        <!-- ==================== -->
        <!-- IMAGES -->
        <!-- ==================== -->
        {% if actualiteShow.media|length > 0 %}
        <div class="p-8 md:p-10">

            <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
                <span class="w-10 h-10 bg-emerald-100 rounded-xl flex items-center justify-center">
                    🖼️
                </span>
                Images liées à cette actualité
            </h2>

            <div class="grid sm:grid-cols-2 md:grid-cols-2 gap-5">

                {% for image in actualiteShow.media %}

                    <div class="overflow-hidden rounded-2xl shadow-md group cursor-pointer">

                        <img src="{{ asset(image.chemindufichier) }}"
                            onclick="openImage('{{ asset(image.chemindufichier) }}')"
                            class="w-full h-56 object-cover group-hover:scale-110 transition duration-500">

                    </div>

                {% endfor %}

            </div>

            <!-- MODAL IMAGE -->
            <div id="imageModal"
                class="hidden fixed inset-0 bg-black/80 z-50 flex items-center justify-center p-4">

                <!-- bouton fermer -->
                <button onclick="closeImage()"
                        class="absolute top-5 right-6 text-white text-4xl font-bold hover:text-red-400">
                    ×
                </button>

                <!-- image -->
                <img id="modalImg"
                    class="max-w-full max-h-[90vh] rounded-xl shadow-2xl">
            </div>

        </div>
        {% endif %}

        <!-- ACTIONS -->
        <div class="px-8 pb-10">

            <div class="flex flex-col sm:flex-row gap-4">

                <a href="{{ path('app_interfacevisiteur') }}#actualites"
                   class="px-6 py-3 rounded-xl bg-emerald-700 text-white font-semibold hover:bg-emerald-800 transition text-center">
                    Retour aux actualités
                </a>

                <a href="{{ path('app_interfacevisiteur') }}"
                   class="px-6 py-3 rounded-xl bg-gray-100 text-gray-800 font-semibold hover:bg-gray-200 transition text-center">
                    Accueil
                </a>

            </div>

        </div>

    </section>

</main>

<footer class="text-center text-sm text-gray-500 py-6">
    © 2026 ORMada - Patrimoine Malagasy
</footer>

<script>

{# Affichage de l'image en grand dans une modal #}
    function openImage(src)
    {
        document.getElementById('modalImg').src = src;
        document.getElementById('imageModal').classList.remove('hidden');
        document.body.style.overflow = "hidden";
    }

    function closeImage()
    {
        document.getElementById('imageModal').classList.add('hidden');
        document.body.style.overflow = "";
    }
</script>

</body>
</html>