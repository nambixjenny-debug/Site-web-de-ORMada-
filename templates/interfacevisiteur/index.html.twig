<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="ORMada - Organisation pour la gestion et la valorisation du patrimoine culturel de Madagascar">
    <meta name="keywords" content="patrimoine, Madagascar, culture, Rova, ORMada">
    <title>ORMada - Patrimoine Malagasy</title>
    
    {# Tailwind CSS #}
    <script src="https://cdn.tailwindcss.com"></script>
    
    {# Styles personnalisés #}
    <style>
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .fade-in {
            animation: fadeIn 0.8s ease-out;
        }

        .hero-overlay {
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.7));
        }

        .hover-lift {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .hover-lift:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }

        html {
            scroll-behavior: smooth;
        }
    </style>
</head>

<body class="bg-gray-50 scroll-auto min-h-screen flex flex-col">

{# HEADER / NAVBAR #}
<header class="fixed top-0 left-0 w-full bg-green-600 shadow-lg z-50">
    <div class="max-w-7xl mx-auto flex justify-between items-center px-4 md:px-6 py-3">
        {# Logo et nom #}
       <div class="flex items-center gap-2 md:gap-3">
            <img src="{{ asset('images/Logo.jpg') }}"
                alt="Blason de Madagascar" 
                class="h-12 w-12 md:h-15 md:w-15 rounded-full object-cover">
            <span class="text-white font-bold text-lg md:text-xl">ORMada</span>
        </div>

        {# Navigation desktop #}
        <nav class="hidden md:flex gap-6 lg:gap-8 text-white font-semibold">
            <a href="#actualites" class="hover:text-yellow-300 transition duration-300">Actualité</a>
            <a href="#evenements" class="hover:text-yellow-300 transition duration-300">Événements</a>
            <a href="#informations" class="hover:text-yellow-300 transition duration-300">Infos</a>
            <a href="#apropos" class="hover:text-yellow-300 transition duration-300">À propos</a>
            <a href="#contacts" class="hover:text-yellow-300 transition duration-300">Contacts</a>
        </nav>

        {# Bouton menu mobile #}
        <button class="md:hidden text-white" onclick="toggleMobileMenu()" aria-label="Menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>
    </div>

    {# Menu mobile #}
    <div id="mobileMenu" class="hidden md:hidden bg-green-700 px-4 py-3">
        <nav class="flex flex-col gap-3 text-white font-semibold">
            <a href="#actualites" onclick="toggleMobileMenu()" class="py-2 hover:bg-green-600 px-3 rounded">Actualité</a>
            <a href="#evenements" onclick="toggleMobileMenu()" class="py-2 hover:bg-green-600 px-3 rounded">Événements</a>
            <a href="#informations" onclick="toggleMobileMenu()" class="py-2 hover:bg-green-600 px-3 rounded">Infos</a>
            <a href="#apropos" onclick="toggleMobileMenu()" class="py-2 hover:bg-green-600 px-3 rounded">À propos</a>
            <a href="#contacts" onclick="toggleMobileMenu()" class="py-2 hover:bg-green-600 px-3 rounded">Contacts</a>
        </nav>
    </div>
</header>

{# MAIN CONTENT #}
<main>

{# Affichage des messages flash #}
{% for type, messages in app.flashes %}
    {% if type == 'success' %}
    <div class="bg-green-50 border-l-4 border-green-600 p-4 m-4 rounded" role="alert">
        <div class="flex">
            <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-green-600" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div class="ml-3">
                <p class="text-sm font-medium text-green-800">
                    {% for message in messages %}
                        {{ message }}{% if not loop.last %}<br>{% endif %}
                    {% endfor %}
                </p>
            </div>
        </div>
    </div>
    {% elseif type == 'error' %}
    <div class="bg-red-50 border-l-4 border-red-600 p-4 m-4 rounded" role="alert">
        <div class="flex">
            <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-600" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div class="ml-3">
                <p class="text-sm font-medium text-red-800">
                    {% for message in messages %}
                        {{ message }}{% if not loop.last %}<br>{% endif %}
                    {% endfor %}
                </p>
            </div>
        </div>
    </div>
    {% endif %}
{% endfor %}

{# SECTION HERO #}
<section class="min-h-screen  bg-center flex items-center justify-center text-center px-4 mt-16" style="background-image:url('images/fondRova.jpg')">
    <div class="p-6 md:p-10 rounded-lg text-white w-full max-w-2xl fade-in">
        <p class="text-sm md:text-base mb-3 opacity-90">
            Pour la gestion et le développement durable du patrimoine de Madagascar
        </p>
        <h1 class="text-3xl md:text-5xl font-bold mb-6">
            Rovan' Madagasikara
        </h1>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a href="{{ path('app_histoire_du_rova') }}"
                class="px-6 py-2 bg-amber-600 hover:bg-amber-700 text-white rounded-lg transition">
                <span class="text-lg">🏰</span>
                <span class="font-medium">Histoire du Rova</span>

            </a>
     
            <button onclick="openModal()"
                    class="bg-green-600 hover:bg-green-700 px-6 py-2 rounded-lg transition duration-300 font-semibold">
                    Contactez-nous
            </button>
        </div>
    </div>
</section>

{# SECTION ACTUALITÉS #}
<section id="actualites" class="py-16 bg-gray-100">
    <div class="max-w-6xl mx-auto px-4">
        
        <h2 class="text-3xl font-bold text-center mb-12">
            Actualités
        </h2>

        <!-- CARROUSEL -->
        <div class="relative overflow-hidden">

            <!-- Slides -->
            <div id="carousel" class="flex transition-transform duration-500">

                <!-- ACTU 1 -->
                <div class="min-w-full grid md:grid-cols-2 gap-8 items-center">
                    <div>
                        <h3 class="text-xl font-bold mb-3">Tsapiky Festival</h3>
                        <p class="text-gray-600 mb-4">
                            Le Rovan’i Madagasikara a vibré au rythme du Tsapiky lors d’un festival exceptionnel réunissant artistes, danseurs et passionnés de culture malgache. Cet événement, organisé en collaboration avec plusieurs acteurs culturels, a mis en lumière la richesse et la diversité musicale du sud de Madagascar.

Durant plusieurs jours, les visiteurs ont pu assister à des performances live, découvrir des danses traditionnelles et participer à des ateliers culturels. Le Tsapiky, connu pour son rythme rapide et entraînant, a su captiver un large public venu de différentes régions du pays.

« Ce festival est une occasion unique de valoriser notre patrimoine musical et de renforcer l’unité culturelle », ont déclaré les organisateurs.

En plus des spectacles, des stands d’artisanat et de gastronomie locale ont permis aux visiteurs de découvrir les savoir-faire traditionnels malgaches dans une ambiance conviviale
                        </p>
                        <button class="bg-black text-white px-4 py-2 rounded-lg">Voir plus...</button>
                    </div>
                    <img src="https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=800"
                         class="rounded-xl shadow-lg h-64 object-cover w-full">
                </div>

                <!-- ACTU 2 -->
                <div class="min-w-full grid md:grid-cols-2 gap-8 items-center">
                    <div>
                        <h3 class="text-xl font-bold mb-3">Rova d’Antananarivo</h3>
                        <p class="text-gray-600 mb-4">
                            Réhabilitation du Rova et ouverture au public.
                        </p>
                        <button class="bg-black text-white px-4 py-2 rounded-lg">Voir plus...</button>
                    </div>
                    <img src="images/fondRova.jpg"
                         class="rounded-xl shadow-lg h-64 object-cover w-full">
                </div>

                <!-- ACTU 3 -->
                <div class="min-w-full grid md:grid-cols-2 gap-8 items-center">
                    <div>
                        <h3 class="text-xl font-bold mb-3">Festival Donia</h3>
                        <p class="text-gray-600 mb-4">
                            Grand festival à Nosy Be avec artistes internationaux.
                        </p>
                        <button class="bg-black text-white px-4 py-2 rounded-lg">Voir plus...</button>
                    </div>
                    <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=800"
                         class="rounded-xl shadow-lg h-64 object-cover w-full">
                </div>

                <!-- ACTU 4 -->
                <div class="min-w-full grid md:grid-cols-2 gap-8 items-center">
                    <div>
                        <h3 class="text-xl font-bold mb-3">Artisanat Malagasy</h3>
                        <p class="text-gray-600 mb-4">
                            Mise en valeur des artisans locaux et produits traditionnels.
                        </p>
                        <button class="bg-black text-white px-4 py-2 rounded-lg">Voir plus...</button>
                    </div>
                    <img src="https://images.unsplash.com/photo-1524492412937-b28074a5d7da?w=800"
                         class="rounded-xl shadow-lg h-64 object-cover w-full">
                </div>

            </div>

      
            <div class="flex flex-col items-center mt-6 space-y-4">

                <!-- Boutons -->
                <div class="flex gap-4">
                    <button onclick="prevSlide()" 
                        class="bg-gray-200 hover:bg-gray-300 text-gray-800 px-5 py-2 rounded-full">
                        <
                        
                    </button>

                    <button onclick="nextSlide()" 
                        class="bg-gray-200 hover:bg-gray-300 text-gray-800 px-5 py-2 rounded-full">
                        >
                    </button>
                </div>

                <!-- Dots -->
                <div id="dots" class="flex gap-2">
                    <span class="dot w-3 h-3 bg-gray-400 rounded-full cursor-pointer"></span>
                    <span class="dot w-3 h-3 bg-gray-400 rounded-full cursor-pointer"></span>
                    <span class="dot w-3 h-3 bg-gray-400 rounded-full cursor-pointer"></span>
                    <span class="dot w-3 h-3 bg-gray-400 rounded-full cursor-pointer"></span>
                </div>

            </div>

        </div>
    </div>
</section>

