{# SECTION INFORMATIONS #}
<section id="informations" class="py-16 md:py-20 bg-gray-100">
    <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-2xl md:text-3xl font-bold text-center mb-12 md:mb-16">
            Informations
        </h2>
        
        <div class="grid md:grid-cols-2 gap-8 md:gap-12">
            <div class="bg-white p-6 rounded-xl shadow-md">
                <h3 class="text-red-600 font-bold text-xl mb-4">
