{# MODAL DE CONTACT #}
<div id="contactModal" 
     class="fixed inset-0 bg-black/60 hidden items-center justify-center z-50 p-4"
     onclick="if(event.target===this) closeModal()">
    
    <div class="bg-white rounded-xl p-6 md:p-8 w-full max-w-md">
        <h2 class="text-2xl text-center font-bold mb-6 text-gray-800">
            Contactez-nous
        </h2>
        
        <form onsubmit="handleSubmit(event)" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Nom complet</label>
                <input type="text" required 
                       class="w-full border border-gray-300 p-3 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                       placeholder="Votre nom">
            </div>
            
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input type="email" required 
                       class="w-full border border-gray-300 p-3 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                       placeholder="votre@email.com">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Titre du message</label>
                <input type="text" required 
                       class="w-full border border-gray-300 p-3 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                       placeholder="Titre de votre message">
            </div>
            
            
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Message</label>
                <textarea required rows="4"
                          class="w-full border border-gray-300 p-3 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                          placeholder="Votre message..."></textarea>
            </div>
            
            <div class="flex gap-3 pt-2">
                <button type="submit" 
                        class="bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition font-semibold flex-1">
                    Envoyer
                </button>
                <button type="button"
                        onclick="closeModal()"
                        class="bg-gray-200 text-gray-800 px-6 py-3 rounded-lg hover:bg-gray-300 transition font-semibold">
                    Annuler
                </button>
            </div>
        </form>
    </div>
</div>

{# SCRIPTS #}
<script>
// Gestion de la modal
function openModal() {
    const modal = document.getElementById('contactModal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden'; // Empêche le scroll
}

function closeModal() {
    const modal = document.getElementById('contactModal');
    modal.classList.add('hidden');
    document.body.style.overflow = 'auto'; // Restaure le scroll
}

// Gestion du menu mobile
function toggleMobileMenu() {
    const menu = document.getElementById('mobileMenu');
    menu.classList.toggle('hidden');
}

// Gestion de la soumission du formulaire
function handleSubmit(e) {
    e.preventDefault();
    
    // Simuler l'envoi du formulaire
    alert('Message envoyé avec succès ! Nous vous répondrons dans les plus brefs délais.');
    closeModal();
    
    // Réinitialiser le formulaire
    e.target.reset();
}

// Fermer la modal avec la touche Echap
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        const modal = document.getElementById('contactModal');
        if (!modal.classList.contains('hidden')) {
            closeModal();
        }
    }
});

// Smooth scroll pour les ancres
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
            target.scrollIntoView({
                behavior: 'smooth',
                block: 'start'
            });
        }
    });
});
</script>

</body>
</html>