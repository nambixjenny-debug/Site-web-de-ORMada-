<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="ORMada - Organisation pour la gestion et la valorisation du patrimoine culturel de Madagascar">
    <meta name="keywords" content="patrimoine, Madagascar, culture, Rova, ORMada">
    <title>ORMada - Patrimoine Malagasy</title>
    
    {# Tailwind CSS #}
    <script src="https://cdn.tailwindcss.com"></script>
    
    {# Styles personnalisés #}
    <style>
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        body{
            font-family: 'Inter', sans-serif;
        }

        /* Titres principaux */
        h1, h2{
            font-family: 'Playfair Display', serif;
            letter-spacing: 0.5px;
        }

        /* Sous-titres */
        h3, h4, h5{
            font-family: 'Poppins', sans-serif;
        }
        .fade-in {
            animation: fadeIn 0.8s ease-out;
        }

        .hero-overlay {
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.7));
        }

        .hover-lift {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .hover-lift:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }

        html {
            scroll-behavior: smooth;
        }
    </style>
</head>

<body class="bg-gray-50 scroll-auto min-h-screen flex flex-col">

{# HEADER / NAVBAR #}
{% include 'interfacevisiteur/NavbarInterfaceVisiteur.html.twig' %}

{# MAIN CONTENT #}
<main>

{# Affichage des messages flash #}
{% for type, messages in app.flashes %}
    {% if type == 'success' %}
    <div class="bg-green-50 border-l-4 border-green-600 p-4 m-4 rounded" role="alert">
        <div class="flex">
            <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-green-600" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div class="ml-3">
                <p class="text-sm font-medium text-green-800">
                    {% for message in messages %}
                        {{ message }}{% if not loop.last %}<br>{% endif %}
                    {% endfor %}
                </p>
            </div>
        </div>
    </div>
    {% elseif type == 'error' %}
    <div class="bg-red-50 border-l-4 border-red-600 p-4 m-4 rounded" role="alert">
        <div class="flex">
            <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-600" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div class="ml-3">
                <p class="text-sm font-medium text-red-800">
                    {% for message in messages %}
                        {{ message }}{% if not loop.last %}<br>{% endif %}
                    {% endfor %}
                </p>
            </div>
        </div>
    </div>
    {% endif %}
{% endfor %}

{# SECTION HERO #}
<section id="Accueil" class="min-h-screen  bg-center flex items-center justify-center text-center px-4 mt-16" style="background-image:url('images/fondRova.jpg')">
    <div class="p-6 md:p-10 rounded-lg text-white w-full max-w-2xl fade-in">
        <p class="text-sm md:text-base mb-3 opacity-90">
            Pour la gestion et le développement durable du patrimoine de Madagascar
        </p>
        <h1 class="text-3xl md:text-5xl font-bold mb-6">
            Rovan' Madagasikara
        </h1>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a href="{{ path('app_histoire_du_rova') }}"
                class="px-6 py-2 bg-amber-600 hover:bg-amber-700 text-white rounded-lg transition">
                <span class="text-lg">🏰</span>
                <span class="font-medium">Histoire du Rova</span>

            </a>
     
            <button onclick="openModal()"
                    class="bg-green-600 hover:bg-green-700 px-6 py-2 rounded-lg transition duration-300 font-semibold">
                    Contactez-nous
            </button>
        </div>
    </div>
</section>

{# 
Partie actualités #}
<section id="actualites" class="py-20 bg-gray-100">

    <div class="max-w-6xl mx-auto px-4">

        <h2 class="text-4xl font-bold text-center mb-12 text-gray-800">
            Actualités
        </h2>
        <p class="text-justify text-gray-600 max-w-3xl mx-auto mb-10 leading-relaxed">
            Restez informés des dernières actualités du site royal d’Antananarivo. 
            Retrouvez ici les annonces importantes, nouveautés, projets en cours, 
            communiqués officiels et informations utiles concernant la valorisation 
            et la préservation de notre patrimoine historique.
        </p>

        <!-- CARROUSEL -->
        <div class="relative overflow-hidden rounded-2xl">

            <!-- Slides -->
            <div id="carousel" class="flex transition-transform duration-500 ease-in-out">

                {% for actualite in actualitesPublier %}

                    <!-- UNE SLIDE = UNE ACTUALITÉ -->
                    <div class="min-w-full px-1">

                        <div class="bg-white rounded-2xl shadow-md p-6 md:p-8 min-h-[420px]">

                            <div class="grid md:grid-cols-2 gap-8 items-stretch">

                                <!-- ===================== -->
                                <!-- CONTENU -->
                                <!-- ===================== -->
                                <div class="flex flex-col justify-center">

                                    <span class="inline-block bg-blue-100 text-blue-700 text-xs font-semibold px-3 py-1 rounded-full mb-3 w-fit">
                                        Actualité
                                    </span>

                                    <h3 class="text-2xl md:text-3xl font-bold text-gray-800 mb-2">
                                        {{ actualite.titre }}
                                    </h3>

                                    <p class="whitespace-pre-line leading-relaxed">
                                        {{ actualite.contenu|slice(0, 120)~'...' }} 
                                        <a href="{{ path('app_showActualite', {'id': actualite.id}) }}"
                                            class="text-gray-600 hover:text-gray-800 font-semibold hover:underline">
                                            Voir plus 
                                        </a>   
                                    </p>

                                </div>
                                <!-- ===================== -->
                                <!-- IMAGES -->
                                <!-- ===================== -->
                                <div class="grid md:grid-cols-1 gap-6 h-full">

                                    
                                  

                                        {% set totalImages = actualite.media|length %}

                                        {# ===================== #}
                                        {# 0 IMAGE #}
                                        {# ===================== #}
                                        {% if totalImages == 0 %}

                                            <img src="{{ asset('images/default.jpg') }}"
                                                class="w-full h-[380px] object-cover rounded-xl shadow">

                                        {# ===================== #}
                                        {# 1 IMAGE #}
                                        {# ===================== #}
                                        {% elseif totalImages == 1 %}

                                            {% set image = actualite.media|first %}

                                            <img src="{{ asset(image.chemindufichier) }}"
                                                class="w-full h-[380px] object-cover rounded-xl shadow hover:scale-105 transition duration-300">
                                        {# ===================== #}
                                        {# 2 IMAGES #}
                                        {# ===================== #}
                                        {% elseif totalImages == 2 %}

                                            <div class="grid grid-cols-2 gap-3 h-[380px]">

                                                {% for image in actualite.media|slice(0,2) %}
                                                    <img src="{{ asset(image.chemindufichier) }}"
                                                        class="w-full h-full object-cover rounded-xl hover:scale-105 transition duration-300">
                                                {% endfor %}

                                            </div>

                                        {# ===================== #}
                                        {# 3+ IMAGES #}
                                        {# ===================== #}
                                        {% else %}

                                            <div class="grid grid-cols-2 gap-3 h-[380px]">

                                                <!-- grande image -->
                                                <div class="row-span-2 overflow-hidden rounded-xl">
                                                    <img src="{{ asset(actualite.media[0].chemindufichier) }}"
                                                        class="w-full h-full object-cover hover:scale-105 transition duration-300">
                                                </div>

                                                <!-- 2e -->
                                                <img src="{{ asset(actualite.media[1].chemindufichier) }}"
                                                    class="w-full h-full object-cover rounded-xl hover:scale-105 transition duration-300">

                                                <!-- 3e + overlay -->
                                                <div class="relative overflow-hidden rounded-xl">

                                                    <img src="{{ asset(actualite.media[2].chemindufichier) }}"
                                                        class="w-full h-full object-cover hover:scale-105 transition duration-300">

                                                    {% if totalImages > 3 %}
                                                        <button
                                                            type="button"
                                                            onclick="openGallery('gallery{{ actualite.id }}')"
                                                            class="absolute inset-0 bg-black/60 text-white text-xl font-bold flex items-center justify-center">
                                                            +{{ totalImages - 3 }}
                                                        </button>
                                                    {% endif %}

                                                </div>

                                            </div>

                                        {% endif %}

                                </div>

                            </div>

                        </div>

                    </div>

                {% else %}

                    <div class="min-w-full text-center py-20 bg-white rounded-2xl shadow">
                        <p class="text-gray-500 text-lg">
                            Aucune actualité disponible.
                        </p>
                    </div>

                {% endfor %}

            </div>

            <!-- =============================== -->
            <!-- BOUTON VOIR PLUS ACTUALITÉS -->
            <!-- =============================== -->
            <div class="mt-3 mx-4 flex justify-start">

                <a href="#"
                class="inline-flex items-center gap-2 bg-emerald-700 hover:bg-emerald-800 text-white font-semibold px-6 py-3 rounded-xl shadow-md hover:shadow-lg transition duration-300">

                    Voir plus d'actualités

                    <svg xmlns="http://www.w3.org/2000/svg"
                        class="w-5 h-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor">

                        <path stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 5l7 7-7 7" />

                    </svg>

                </a>

            </div>

            

            <!-- CONTROLS -->
            <div class="flex flex-col items-center mt-8 space-y-4">

                <!-- Boutons -->
                <div class="flex gap-4">

                    <button onclick="prevSlide()"
                        class="w-10 h-10 rounded-full bg-white shadow hover:bg-gray-200 transition">
                        ‹
                    </button>

                    <button onclick="nextSlide()"
                        class="w-10 h-10 rounded-full bg-white shadow hover:bg-gray-200 transition">
                        ›
                    </button>

                </div>

                <!-- Dots dynamiques -->
                <div id="dots" class="flex gap-2">
                    {% for actualite in actualitesPublier %}
                        <span class="dot w-3 h-3 bg-gray-400 rounded-full cursor-pointer transition"></span>
                    {% endfor %}
                </div>

            </div>

        </div>

    </div>

</section>





{# SECTION ÉVÉNEMENTS #}
<section id="evenements" class="py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4">

        <h2 class="text-2xl md:text-3xl font-bold text-center mb-6 md:mb-6">
            Événements
        </h2>

        <p class="text-justify text-gray-600 max-w-3xl mx-auto mb-10 leading-relaxed">
            Découvrez les événements marquants organisés au sein du site royal d’Antananarivo. 
            Entre activités culturelles, visites guidées, expositions et animations éducatives, 
            chaque rendez-vous est une occasion unique de valoriser notre patrimoine historique 
            et de partager des moments enrichissants avec le public.
        </p>

        <div class="grid md:grid-cols-3 gap-6 md:gap-8">

            {% for evenement in evenements %}

                <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition">

                    {# IMAGE PRINCIPALE #}
                    {% set image = evenement.media|first %}

                    {% if image %}
                        <img src="{{ asset(image.chemindufichier) }}"
                             class="h-48 w-full object-cover"
                             alt="{{ evenement.titre }}">
                    {% else %}
                        <img src="{{ asset('images/default.jpg') }}"
                             class="h-48 w-full object-cover"
                             alt="default">
                    {% endif %}

                    <div class="p-5">

                        <span class="text-sm text-green-600 font-semibold">
                           Du {{ evenement.datedudebut|date('d/m/Y') }}
                        </span>
                        <span class="text-sm text-green-600 font-semibold">
                           au {{ evenement.datedufin|date('d/m/Y') }}
                        </span>


                        <h3 class="font-bold text-xl mb-2 mt-1">
                            {{ evenement.titre }}
                        </h3>

                        <p class="text-gray-600 mb-4">
                            {{ evenement.description|slice(0,120) }}...
                        </p>

                        <a href="{{ path('app_showevenement', {'id': evenement.id}) }}"
                           class="text-green-600 font-semibold hover:underline">
                            Voir plus →
                        </a>

                    </div>
                </div>

            {% else %}

                <p class="text-center text-gray-500 col-span-3">
                    Aucun événement disponible.
                </p>

            {% endfor %}

        </div>
          <!-- =============================== -->
        <!-- BOUTON VOIR PLUS ÉVÉNEMENTS -->
        <!-- =============================== -->
        <div class="mt-10 mx-4 flex justify-start">

            <a href="#"
            class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold px-6 py-3 rounded-xl shadow-md hover:shadow-lg transition duration-300">

                Voir plus d'événements

                <svg xmlns="http://www.w3.org/2000/svg"
                    class="w-5 h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor">

                    <path stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 5l7 7-7 7" />

                </svg>

            </a>

        </div>
    </div>

  
</section>

{# SECTION INFORMATIONS #}
<section id="informations" class="py-16 md:py-20 bg-gray-100">
    <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-2xl md:text-3xl font-bold text-center mb-12 md:mb-16">
            Informations
        </h2>
        
        <div class="grid md:grid-cols-2 gap-8 md:gap-12">
            <div class="max-w-4xl mx-auto space-y-8">

                <!-- ======================= -->
                <!-- BLOC CULTURE ET FADY -->
                <!-- ======================= -->
                <div class="bg-white p-6 md:p-8 rounded-2xl shadow-lg border border-gray-100 hover:shadow-xl transition duration-300">

                    <div class="flex items-center gap-3 mb-5">
                        <div class="w-12 h-12 bg-red-100 text-red-600 rounded-full flex items-center justify-center text-2xl">
                            🏛️
                        </div>

                        <div>
                            <h3 class="text-2xl font-bold text-gray-800">
                                Cultures et fady
                            </h3>

                            <p class="text-sm text-gray-500">
                                Rovan'i Madagasikara
                            </p>
                        </div>
                    </div>

                    <p class="text-gray-700 leading-relaxed text-justify">
                        Le Rovan’i Madagasikara n’est pas seulement un site historique, 
                        mais aussi un lieu profondément ancré dans les traditions et croyances malgaches.
                        Pour préserver son caractère sacré et respecter la mémoire des souverains, 
                        certaines règles culturelles appelées <strong>fady</strong> doivent être respectées 
                        par tous les visiteurs.
                    </p>

                    <button onclick="openFadyModal()"
                       class="mt-5 inline-flex items-center justify-center
                            border border-emerald-700
                            text-emerald-700
                            hover:bg-emerald-600 hover:text-white
                            px-6 py-2 rounded-2xl
                            font-semibold tracking-wide
                            shadow-md hover:shadow-xl
                            transition duration-300
                            hover:-translate-y-1 active:scale-15">
                        En savoir plus...
                    </button>

                </div>


                <!-- ======================= -->
                <!-- BLOC HORAIRES -->
                <!-- ======================= -->
                <div class="bg-white p-6 md:p-8 rounded-2xl shadow-lg border border-gray-100 hover:shadow-xl transition duration-300">

                    <div class="flex items-center gap-3 mb-5">
                        <div class="w-12 h-12 bg-green-100 text-green-600 rounded-full flex items-center justify-center text-2xl">
                            🕒
                        </div>

                        <div>
                            <h3 class="text-2xl font-bold text-gray-800">
                                Horaires de visite
                            </h3>

                            <p class="text-sm text-gray-500">
                                Rovan'ny Manjakamiadana
                            </p>
                        </div>
                    </div>

                    <div class="space-y-4">

                        <div class="flex justify-between items-center bg-gray-50 rounded-xl px-4 py-3">
                            <span class="text-gray-600 font-medium">Jours d'ouverture</span>
                            <span class="font-semibold text-green-600">Mercredi - Lundi</span>
                        </div>

                        <div class="flex justify-between items-center bg-gray-50 rounded-xl px-4 py-3">
                            <span class="text-gray-600 font-medium">Ouverture</span>
                            <span class="font-semibold text-blue-600">09h00</span>
                        </div>

                        <div class="flex justify-between items-center bg-gray-50 rounded-xl px-4 py-3">
                            <span class="text-gray-600 font-medium">Fermeture</span>
                            <span class="font-semibold text-red-500">17h00</span>
                        </div>

                        <div class="flex justify-between items-center bg-red-50 rounded-xl px-4 py-3">
                            <span class="text-gray-600 font-medium">Jour fermé</span>
                            <span class="font-semibold text-red-600">Mardi</span>
                        </div>

                    </div>

                    <div class="mt-5 text-sm text-gray-500 text-center border-t pt-4">
                        Les horaires peuvent changer selon les jours fériés ou événements spéciaux.
                    </div>

                </div>

            </div>



        {# Modal qui affiche tous les fady liés au Rova de Manjakamiadana #}
                
                {# Modal qui affiche tous les fady liés au Rova de Manjakamiadana #}

        <div id="fadyModal"
            class="fixed inset-0 bg-black/60 hidden items-center justify-center z-50 p-4 overflow-y-auto">

            <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full relative
            max-h-[90vh] overflow-y-auto no-scrollbar">

                <!-- HEADER -->
                <div class="sticky top-0 bg-white z-10 border-b border-gray-200 px-6 py-5 rounded-t-2xl flex items-center justify-between">

                    <h2 class="text-2xl md:text-3xl font-bold text-gray-800">
                        Les Fady du Rova d'Antananarivo
                    </h2>

                    <button onclick="closeFadyModal()"
                        class="text-gray-600 hover:text-red-600 text-2xl font-bold transition">
                        ✖
                    </button>

                </div>

                <!-- CONTENT -->
                <div class="p-6 md:p-8">

                    <div class="flex gap-3 mb-[20px] text-justify">

                        <span class="text-red-600 text-xl shrink-0">🚫</span>

                        <p class="text-gray-700 leading-relaxed">
                            Il est interdit de pointer du doigt les tombes royales ou les palais. 
                            Ce geste est considéré comme irrespectueux envers les ancêtres et les souverains 
                            qui reposent sur le site. Il est préférable d’indiquer avec la main ouverte par respect.
                        </p>

                    </div>

                    <div class="flex gap-3 mb-[20px]">

                        <span class="text-red-600 text-xl shrink-0">📷</span>

                        <p class="text-gray-700 leading-relaxed">
                            La prise de photos peut être interdite dans certaines zones sacrées du Rova. 
                            Ces restrictions visent à préserver le caractère spirituel et la dignité des lieux. 
                            Il est recommandé de toujours demander l’autorisation avant de photographier.
                        </p>

                    </div>

                    <div class="flex gap-3 mb-[20px]">

                        <span class="text-red-600 text-xl shrink-0">🕊</span>

                        <p class="text-gray-700 leading-relaxed">
                            Les tombes des rois et reines sont des lieux sacrés. Les visiteurs doivent éviter 
                            de marcher ou de s’asseoir à proximité de ces espaces et adopter une attitude respectueuse, 
                            car ils sont considérés comme des lieux de mémoire et de recueillement.
                        </p>

                    </div>

                    <div class="flex gap-3 mb-[20px]">

                        <span class="text-red-600 text-xl shrink-0">🙏</span>

                        <p class="text-gray-700 leading-relaxed">
                            Un comportement respectueux est exigé sur l’ensemble du site. Cela inclut une tenue correcte, 
                            une attitude calme et le respect des consignes données par les guides ou les responsables du Rova.
                        </p>

                    </div>

                    <div class="flex gap-3 mb-[20px]">

                        <span class="text-red-600 text-xl shrink-0">🍽</span>

                        <p class="text-gray-700 leading-relaxed">
                            Certains aliments peuvent être interdits selon les traditions locales (fady). 
                            Ces interdits varient selon les croyances et les coutumes. Il est conseillé 
                            de se renseigner auprès des guides pour éviter toute offense culturelle.
                        </p>

                    </div>

                    <div class="flex gap-3">

                        <span class="text-red-600 text-xl shrink-0">🤫</span>

                        <p class="text-gray-700 leading-relaxed">
                            Le silence et le calme sont fortement recommandés dans les zones sacrées. 
                            Faire du bruit ou perturber l’environnement peut être perçu comme un manque de respect 
                            envers les ancêtres et l’importance spirituelle du lieu.
                        </p>

                    </div>

                </div>

            </div>

        </div>

        <style>

            /* Cache la scrollbar mais garde le scroll */
            .no-scrollbar::-webkit-scrollbar {
                display: none;
            }

            .no-scrollbar {
                -ms-overflow-style: none;
                scrollbar-width: none;
            }

        </style>
       

        
{#      Inforamtion sur les tarifs d'entrée du Rova de Manjakamiadana #}
            
            <div class="max-w-4xl mx-auto ">
    
                <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100">

                    <!-- Bandeau décoratif -->
                    <div class="h-1.5 bg-gradient-to-r from-emerald-600 via-emerald-500 to-emerald-400"></div>

                    <div class="p-6 md:p-7">

                        <!-- HEADER -->
                        <div class="text-center mb-6">

                            <div class="inline-flex items-center justify-center w-14 h-14 bg-emerald-100 rounded-full mb-3 shadow-sm">
                                <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z">
                                    </path>
                                </svg>
                            </div>

                            <h3 class="text-2xl md:text-3xl font-bold text-gray-800 mb-2">
                                Tarifs d'entrée au Rova 
                            </h3>

                            <div class="w-16 h-1 bg-emerald-500 mx-auto rounded-full mb-3"></div>

                            <p class="text-gray-600 text-sm md:text-base leading-relaxed max-w-2xl mx-auto">
                                Les tarifs varient selon la nationalité, l'âge et le type de visite.
                                Une réduction est accordée aux groupes de 5 personnes ou plus.
                            </p>

                        </div>

                        
                        <!-- BLOCS -->
                        <div class="space-y-4">

                            <!-- VISITE COMPLETE -->
