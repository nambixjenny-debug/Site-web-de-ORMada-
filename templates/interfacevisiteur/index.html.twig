{# MODAL DE CONTACT #}
<div id="contactModal" 
     class="fixed inset-0 bg-black/60 hidden items-center justify-center z-50 p-4"
     onclick="if(event.target===this) closeModal()">
    
    <div class="bg-white rounded-xl p-6 md:p-8 w-full max-w-md max-h-106 overflow-y-auto">
        <h2 class="text-2xl text-center font-bold mb-6 text-gray-800">
            Contactez-nous
        </h2>
        
        <!-- Formulaire AJAX pour éviter les problèmes CSRF -->
        <form id="contactFormAjax" class="space-y-6">
            
            <!-- Champ NOM -->
            <div class="form-group">
                <label for="contact_nom" class="block text-sm font-semibold text-gray-700 mb-2">Nom</label>
                <input type="text" id="contact_nom" name="nom" placeholder="Votre nom" 
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200" 
                       required>
                <div class="text-red-500 text-xs mt-1 error-nom"></div>
            </div>

            <!-- Champ EMAIL -->
            <div class="form-group">
                <label for="contact_email" class="block text-sm font-semibold text-gray-700 mb-2">Email</label>
                <input type="email" id="contact_email" name="email" placeholder="votre.email@example.com" 
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200" 
                       required>
                <div class="text-red-500 text-xs mt-1 error-email"></div>
            </div>

            <!-- Champ TITRE -->
            <div class="form-group">
                <label for="contact_titre" class="block text-sm font-semibold text-gray-700 mb-2">Titre/Sujet</label>
                <input type="text" id="contact_titre" name="titre" placeholder="Sujet de votre message" 
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200" 
                       required>
                <div class="text-red-500 text-xs mt-1 error-titre"></div>
            </div>

            <!-- Champ DESCRIPTION -->
            <div class="form-group">
                <label for="contact_description" class="block text-sm font-semibold text-gray-700 mb-2">Message</label>
                <textarea id="contact_description" name="description" placeholder="Votre message" rows="4"
                          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200" 
                          required></textarea>
                <div class="text-red-500 text-xs mt-1 error-description"></div>
            </div>

            <!-- Erreur générale -->
            <div id="contact_error" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded"></div>

            <!-- BOUTONS -->
            <div class="flex justify-between pt-6 border-t gap-3">
                <button type="button" onclick="closeModal()"
                   class="text-gray-600 hover:text-gray-900 text-sm px-5 py-2 rounded-md border border-gray-300 hover:bg-gray-100 transition">
                    ← Annuler
                </button>

                <button type="submit" id="submitBtn"
                    class="bg-green-600 hover:bg-green-700 text-white text-sm px-5 py-2 rounded-md transition">
                    Envoyer
                </button>
            </div>

        </form>
            
    </div>
</div>


{# SCRIPTS #}
<script>
// Gestion de la modal
function openModal() {
    const modal = document.getElementById('contactModal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
    resetContactForm();
}

function closeModal() {
    const modal = document.getElementById('contactModal');
    modal.classList.add('hidden');
    document.body.style.overflow = 'auto';
}

function resetContactForm() {
    const form = document.getElementById('contactFormAjax');
    if (form) {
        form.reset();
    }
    // Réinitialiser les messages d'erreur
    document.getElementById('contact_error').classList.add('hidden');
    document.querySelectorAll('[class^="error-"]').forEach(el => el.textContent = '');
}

// Soumission du formulaire de contact en AJAX
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('contactFormAjax');
    if (form) {
        form.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const submitBtn = document.getElementById('submitBtn');
            const originalText = submitBtn.textContent;
            submitBtn.disabled = true;
            submitBtn.textContent = 'Envoi en cours...';
            
            // Récupérer les données du formulaire
            const formData = {
                nom: document.getElementById('contact_nom').value,
                email: document.getElementById('contact_email').value,
                titre: document.getElementById('contact_titre').value,
                description: document.getElementById('contact_description').value
            };

            try {
                const response = await fetch('{{ path("api_contact_submit") }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify(formData)
                });

                const result = await response.json();

                if (result.success) {
                    // Afficher le message de succès
                    showSuccessMessage('Votre message a bien été envoyé !');
                    resetContactForm();
                    setTimeout(() => closeModal(), 1500);
                } else {
                    showErrorMessage(result.error || 'Erreur lors de l\'envoi');
                }
            } catch (error) {
                showErrorMessage('Erreur réseau: ' + error.message);
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = originalText;
            }
        });
    }
});

function showSuccessMessage(message) {
    const alertDiv = document.createElement('div');
    alertDiv.className = 'fixed top-4 right-4 bg-green-50 border-l-4 border-green-600 p-4 rounded shadow-lg z-50 max-w-sm';
    alertDiv.innerHTML = `
        <div class="flex">
            <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-green-600" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div class="ml-3">
                <p class="text-sm font-medium text-green-800">${message}</p>
            </div>
        </div>
    `;
    document.body.appendChild(alertDiv);
    
    setTimeout(() => {
        alertDiv.remove();
    }, 3000);
}

function showErrorMessage(message) {
    const errorDiv = document.getElementById('contact_error');
    errorDiv.textContent = message;
    errorDiv.classList.remove('hidden');
}

// Fermer la modal avec la touche Echap
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        const modal = document.getElementById('contactModal');
        if (!modal.classList.contains('hidden')) {
            closeModal();
        }
    }
});

// Gestion du menu mobile
function toggleMobileMenu() {
    const menu = document.getElementById('mobileMenu');
    menu.classList.toggle('hidden');
}

{# Gestion du carrousel #}

let currentSlide = 0;

function showSlide (){
    const carousel = document.getElementById('carousel');
    carousel.style.transform = `translateX(-${currentSlide * 100}%)`;
    updateDots();
}

function nextSlide(){
    const totalSlides = document.querySelectorAll('#carousel > div').length;
    currentSlide = (currentSlide + 1) % totalSlides;
    showSlide();
}

function prevSlide(){
    const totalSlides = document.querySelectorAll('#carousel > div').length;
    currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
    showSlide();
}

{# clic sur les dots pour aller à une slide spécifique #}

function updateDots(){
    const dots = document.querySelectorAll('.dot');
    dots.forEach((dot, i) => {
        dot.classList.remove('bg-red-800');
        dot.classList.add('bg-gray-400');

        if (i === currentSlide){
            dot.classList.remove('bg-gray-400');
            dot.classList.add('bg-red-800');

        }
    })
}

document.querySelectorAll(".dot").forEach((dot, i) => {
    dot.addEventListener("click", () => {
        currentSlide = i;
        showSlide();
    });
});
showSlide();



// Smooth scroll pour les ancres
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
            target.scrollIntoView({
                behavior: 'smooth',
                block: 'start'
            });
        }
    });
});


{# affichage du modal pour Fady #}
function openFadyModal(){
    document.getElementById("fadyModal").classList.remove("hidden");
    document.getElementById("fadyModal").classList.add("flex");
    }

function closeFadyModal(){
    document.getElementById("fadyModal").classList.remove("flex");
    document.getElementById("fadyModal").classList.add("hidden");
}



</script>

</body>
</html>