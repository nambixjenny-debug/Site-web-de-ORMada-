{% extends 'base.html.twig' %}

{% block title %}Actualités - ORMada{% endblock %}

{% block body %}
    <div class="h-screen overflow-hidden bg-gradient-to-br from-slate-100 via-emerald-50 to-white flex flex-col">

         <!-- HEADER -->
        <section class="shrink-0 bg-gradient-to-r from-emerald-800 via-emerald-700 to-emerald-600 shadow-2xl">

            <div class="max-w-7xl mx-auto px-6 py-4 flex flex-col md:flex-row md:items-center md:justify-between gap-2">

                <div>

                    <h1 class="text-4xl font-bold text-white">
                        Gestion des actualités
                    </h1>

                    <p class="text-emerald-100 mt-2 text-sm tracking-wide">
                        Administration ORMada
                    </p>

                </div>

                <form method="get">
<div class="flex flex-col md:flex-row items-stretch md:items-center gap-3">

    <!-- RECHERCHE -->
    <div class="flex-1">

        <div class="relative">

            <input
                type="text"
                name="search"
                value="{{ app.request.get('search') }}"
                placeholder="Titre ou contenu..."
                class="w-full px-4 py-2.5 pr-11
                       rounded-xl
                       border border-gray-200
                       bg-gray-50
                       text-sm text-gray-700
                       placeholder-gray-400
                       focus:bg-white
                       focus:ring-2 focus:ring-emerald-500
                       focus:border-emerald-500
                       focus:outline-none
                       transition duration-300"
            >

        </div>

    </div>

    <!-- STATUS -->
    <div class="w-[40px] md:w-22">

        <select
            name="publier"
            class="w-full px-4 py-2.5
                   rounded-xl
                   border border-gray-200
                   bg-gray-50
                   text-sm text-gray-700
                   focus:bg-white
                   focus:ring-2 focus:ring-emerald-500
                   focus:border-emerald-500
                   focus:outline-none
                   transition duration-300">

            <option value="">Tous</option>

            <option value="1"
                {% if app.request.get('publier') == '1' %}
                    selected
                {% endif %}
            >
                Publié
            </option>

            <option value="0"
                {% if app.request.get('publier') == '0' %}
                    selected
                {% endif %}
            >
                Non publié
            </option>

        </select>

    </div>

    <!-- BUTTON -->
    <div>

        <button
            type="submit"
            class="w-full md:w-auto px-5 py-2.5 rounded-xl
                   bg-emerald-700 hover:bg-emerald-800
                   text-sm text-white font-semibold
                   shadow-md hover:shadow-xl
                   transition duration-300">

            Rechercher

        </button>

    </div>

</div>

  

   
   

</form>

                <a href="{{ path('app_actualite_new') }}"
                class="inline-flex items-center justify-center gap-1 px-6 py-2 bg-emerald-500 hover:bg-emerald-600 rounded-2xl  text-white font-semibold shadow-lg hover:shadow-2xl hover:-translate-y-1 transition duration-300">

                    <span class="text-xl">+</span>
                    <span>Créer une actualité</span>

                </a>

            </div>

        </section>

        <!-- Table Section -->
        <div class="bg-white rounded-xl shadow-xl overflow-hidden border border-green-100 mt-3">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gradient-to-r from-emerald-700 via-emerald-500 to-emerald-400 text-white">
                        <tr>
                            <th class="px-6 py-4 text-left font-semibold">ID</th>
                            <th class="px-6 py-4 text-left font-semibold">images</th>
                            <th class="px-6 py-4 text-left font-semibold">Titre</th>
                            <th class="px-6 py-4 text-left font-semibold">Contenu</th>
                            <th class="px-6 py-4 text-left font-semibold">Date</th>
                            <th class="px-6 py-4 text-left font-semibold">Statut</th>
                            <th class="px-6 py-4 text-left font-semibold">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-green-100">
                    {% for actualite in actualites %}
                        <tr class="hover:bg-green-50 transition-colors">
                            <td class="px-6 py-4 font-semibold text-gray-900">#{{ actualite.id }}</td>
                            <td class="px-2 py-2">
                                {% set image = actualite.media|first %}
                                {% if image %}
                                    <img src="{{ asset(image.chemindufichier) }}" alt="{{ actualite.titre }}" class="h-20 w-20 object-cover rounded">
                                {% else %}
                                    <img src="{{ asset('images/default.jpg') }}" alt="{{ actualite.titre }}" class="w-full h-28 object-cover rounded-lg">
                                {% endif %}
                            </td>
                            <td class="px-6 py-4"><span class="font-semibold text-gray-900">{{ actualite.titre }}</span></td>
                            <td class="px-6 py-4 text-gray-600 max-w-xs truncate">{{ actualite.contenu }}</td>
                            <td class="px-6 py-4 text-gray-700">{{ actualite.publierle ? actualite.publierle|date('d/m/Y') : 'N/A' }}</td>
                            <td class="px-6 py-4">
                                {% if actualite.dejapublier %}
                                    <span class="inline-flex items-center gap-2 bg-green-100 text-green-800 px-4 py-2 rounded-full text-sm font-semibold">✓ Publié</span>
                                {% else %}
                                    <span class="inline-flex items-center gap-2 bg-yellow-100 text-yellow-800 px-4 py-2 rounded-full text-sm font-semibold">⏱ En attente</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 flex gap-3">
                                <a href="{{ path('app_actualite_show', {'id': actualite.id}) }}" class="text-green-600 hover:text-green-800 font-semibold hover:underline">👁️ Voir</a>
                                <a href="{{ path('app_actualite_edit', {'id': actualite.id}) }}" class="text-blue-600 hover:text-blue-800 font-semibold hover:underline">✏️ Éditer</a>
                                {{ include('actualite/_delete_form.html.twig') }}
                                
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="px-6 py-8 text-center text-gray-500">
                                <div class="text-6xl mb-4">📭</div>
                                <p class="text-lg font-semibold">Aucune actualité trouvée</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
