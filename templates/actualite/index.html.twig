{% extends 'base.html.twig' %}

{% block title %}Actualités - ORMada{% endblock %}

{% block body %}
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="mb-12">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h2 class="text-5xl font-bold text-gray-700 mb-2">📰 Actualités</h2>
                    <p class="text-gray-700 text-lg">Gérez l'ensemble de vos actualités</p>
                </div>
                <a href="{{ path('app_actualite_new') }}" class="bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white font-bold py-3 px-8 rounded-lg shadow-lg hover:shadow-xl transition-all transform hover:scale-105">
                    ➕ Nouvelle Actualité
                </a>
            </div>
        </div>

        <!-- Table Section -->
        <div class="bg-white rounded-xl shadow-xl overflow-hidden border border-green-100">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gradient-to-r from-green-600 via-emerald-500 to-emerald-400 text-white">
                        <tr>
                            <th class="px-6 py-4 text-left font-semibold">ID</th>
                            <th class="px-6 py-4 text-left font-semibold">images</th>
                            <th class="px-6 py-4 text-left font-semibold">Titre</th>
                            <th class="px-6 py-4 text-left font-semibold">Contenu</th>
                            <th class="px-6 py-4 text-left font-semibold">Date</th>
                            <th class="px-6 py-4 text-left font-semibold">Statut</th>
                            <th class="px-6 py-4 text-left font-semibold">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-green-100">
                    {% for actualite in actualites %}
                        <tr class="hover:bg-green-50 transition-colors">
                            <td class="px-6 py-4 font-semibold text-gray-900">#{{ actualite.id }}</td>
                            <td class="px-2 py-2">
                                {% set image = actualite.media|first %}
                                {% if image %}
                                    <img src="{{ asset(image.chemindufichier) }}" alt="{{ actualite.titre }}" class="h-20 w-20 object-cover rounded">
                                {% else %}
                                    <img src="{{ asset('images/default.jpg') }}" alt="{{ actualite.titre }}" class="w-full h-28 object-cover rounded-lg">
                                {% endif %}
                            </td>
                            <td class="px-6 py-4"><span class="font-semibold text-gray-900">{{ actualite.titre }}</span></td>
                            <td class="px-6 py-4 text-gray-600 max-w-xs truncate">{{ actualite.contenu }}</td>
                            <td class="px-6 py-4 text-gray-700">{{ actualite.publierle ? actualite.publierle|date('d/m/Y') : 'N/A' }}</td>
                            <td class="px-6 py-4">
                                {% if actualite.dejapublier %}
                                    <span class="inline-flex items-center gap-2 bg-green-100 text-green-800 px-4 py-2 rounded-full text-sm font-semibold">✓ Publié</span>
                                {% else %}
                                    <span class="inline-flex items-center gap-2 bg-yellow-100 text-yellow-800 px-4 py-2 rounded-full text-sm font-semibold">⏱ En attente</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 flex gap-3">
                                <a href="{{ path('app_actualite_show', {'id': actualite.id}) }}" class="text-green-600 hover:text-green-800 font-semibold hover:underline">👁️ Voir</a>
                                <a href="{{ path('app_actualite_edit', {'id': actualite.id}) }}" class="text-blue-600 hover:text-blue-800 font-semibold hover:underline">✏️ Éditer</a>
                                {{ include('actualite/_delete_form.html.twig') }}
                                
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="px-6 py-8 text-center text-gray-500">
                                <div class="text-6xl mb-4">📭</div>
                                <p class="text-lg font-semibold">Aucune actualité trouvée</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
