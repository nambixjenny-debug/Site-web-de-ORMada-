{{ form_start(form, {'attr': {'class': 'space-y-3'}}) }}
    <div class="grid grid-cols-1 gap-3">
        {% for child in form %}
            {% if child.vars.name != 'csrf_token' %}
                <div>
                    {{ form_label(child, null, {
                        'label_attr': {
                            'class': 'block text-xs font-bold text-gray-900 mb-1'
                        }
                    }) }}
                    <div class="relative">
                        {{ form_widget(child, {
                            'attr': {
                                'class': 'w-full px-3 py-2 border-2 border-gray-200 rounded-lg focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200 transition-colors duration-200 text-gray-900 text-sm'
                            }
                        }) }}
                    </div>
                    {% if form_errors(child) %}
                        <div class="mt-1 text-red-600 text-xs font-medium">
                            {{ form_errors(child) }}
                        </div>
                    {% endif %}
                </div>
            {% endif %}
        {% endfor %}
    </div>

    <!-- Submit Button -->
    <div class="flex items-center gap-3 pt-4 border-t border-gray-200 mt-4">
        <button type="submit" class="bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white font-bold py-2 px-6 rounded-lg shadow-lg hover:shadow-xl transition-all transform hover:scale-105 text-sm">
            <span class="flex items-center gap-2">
                <span>💾</span>
                <span>{{ button_label|default('Enregistrer') }}</span>
            </span>
        </button>
        <a href="{{ path('app_actualite_index') }}" class="text-gray-600 hover:text-gray-900 font-semibold px-4 py-2 text-center transition-colors text-sm">
            Annuler
        </a>
    </div>

{{ form_end(form) }}
