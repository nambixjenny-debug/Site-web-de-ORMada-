{% extends 'base.html.twig' %}

{% block title %}Modifier actualité - ORMada{% endblock %}

{% block body %}
    <div class="max-w-4xl">
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-4xl font-bold text-gray-800 mb-2 flex items-center gap-3">
                <span class="text-4xl">✏️</span>
                Modifier l'actualité
            </h1>
            <p class="text-gray-600">Mettez à jour les détails de cette actualité</p>
        </div>

        <!-- Form Card -->
        <div class="bg-white rounded-xl shadow-lg p-8 border-l-4 border-emerald-500 mb-8">
            {{ include('actualite/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
        </div>


        <!-- Delete Section -->
        <div class="mt-8 pt-8 border-t border-gray-300">
            <h3 class="text-lg font-semibold text-gray-800 mb-4 flex items-center gap-2">
                <span>⚠️</span>
                Zone de danger
            </h3>
            {{ include('actualite/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
