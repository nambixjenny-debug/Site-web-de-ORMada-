{% extends 'base.html.twig' %}

{% block title %}Modifier utilisateur - ORMada{% endblock %}

{% block body %}

<div class="min-h-screen bg-gradient-to-br from-slate-100 via-emerald-50 to-white py-10 px-4">

    <div class="max-w-4xl mx-auto">

        <!-- HEADER -->
        <div class="mb-8">

            <a href="{{ path('app_user_index') }}"
               class="inline-flex items-center gap-2 text-emerald-700 hover:text-emerald-900 font-semibold transition mb-5">

                <span>←</span>
                <span>Retour à la liste</span>

            </a>

            <div class="bg-gradient-to-r from-emerald-900 via-emerald-800 to-emerald-700 rounded-3xl shadow-2xl overflow-hidden">

                <!-- TOP BAR -->
                <div class="h-2 bg-gradient-to-r from-yellow-400 via-emerald-400 to-white"></div>

                <div class="px-8 py-10 text-white">

                    <div class="flex items-center gap-5">

                        <div class="w-20 h-20 rounded-3xl bg-white/20 backdrop-blur-md flex items-center justify-center text-4xl shadow-xl">
                            ✏️
                        </div>

                        <div>

                            <h1 class="text-4xl font-bold leading-tight">
                                Modifier utilisateur
                            </h1>

                            <p class="text-emerald-100 mt-2 tracking-wide">
                                Modifier les informations administrateur ORMada
                            </p>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- FORM CARD -->
        <div class="bg-white rounded-3xl shadow-2xl border border-gray-100 overflow-hidden">

            <!-- BAR -->
            <div class="h-2 bg-gradient-to-r from-emerald-700 via-emerald-500 to-yellow-500"></div>

            <div class="p-8 md:p-10">

                <div class="mb-8">

                    <h2 class="text-2xl font-bold text-gray-800 mb-2">
                        Informations utilisateur
                    </h2>

                    <p class="text-gray-500">
                        Modifiez l’adresse email, les rôles et le mot de passe.
                    </p>

                </div>

                <!-- FORM -->
                <div class="space-y-6">

                    {{ include('user/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

                </div>

            </div>

        </div>

        <!-- DELETE SECTION -->
        <div class="mt-8 bg-white rounded-3xl shadow-xl border border-red-100 overflow-hidden">

            <!-- TOP -->
            <div class="h-2 bg-gradient-to-r from-red-700 via-red-500 to-red-400"></div>

            <div class="p-8">

                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">

                    <div>

                        <h3 class="text-2xl font-bold text-red-700 mb-2">
                            Supprimer cet utilisateur
                        </h3>

                        <p class="text-gray-500 leading-relaxed">
                            Cette action est irréversible. Toutes les données liées à cet utilisateur seront définitivement supprimées.
                        </p>

                    </div>

                    <div class="w-full md:w-auto">

                        {{ include('user/_delete_form.html.twig') }}

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

{% endblock %}