{% extends 'base.html.twig' %}

{% block title %}Créer un utilisateur{% endblock %}

{% block body %}

<section class="min-h-screen bg-gradient-to-br from-emerald-50 via-white to-gray-100 py-12 px-4">

    <div class="max-w-2xl mx-auto">

        <!-- HEADER -->
        <div class="text-center mb-10">

            <h1 class="text-4xl font-bold text-gray-800 mb-3">
                Créer un administrateur
            </h1>

            <p class="text-gray-500 max-w-lg mx-auto">
                Ajoutez un nouvel utilisateur administrateur pour accéder au tableau de bord sécurisé ORMada.
            </p>

        </div>

        <!-- CARD -->
        <div class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-gray-100">

            <!-- TOP BAR -->
            <div class="h-2 bg-gradient-to-r from-emerald-700 via-emerald-500 to-yellow-500"></div>

            <div class="p-8 md:p-10">

                {{ form_start(form) }}

                <div class="space-y-7">

                    <!-- EMAIL -->
                    <div>

                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                            Adresse email
                        </label>

                        {{
                            form_widget(form.email, {
                                attr: {
                                    class: 'w-full rounded-2xl border border-gray-300 px-5 py-3 focus:ring-2 focus:ring-emerald-500 focus:outline-none bg-gray-50'
                                }
                            })
                        }}

                        <div class="mt-2 text-sm text-red-500">
                            {{ form_errors(form.email) }}
                        </div>

                    </div>

                    <!-- ROLE -->
                    <div>

                        <label class="block text-sm font-semibold text-gray-700 mb-3">
                            Rôle administrateur
                        </label>

                        <div class="bg-emerald-50 border border-emerald-100 rounded-2xl p-5">

                            <div class="flex items-center gap-3">

                                {{
                                    form_widget(form.roles, {
                                        attr: {
                                            class: 'w-5 h-5 text-emerald-600 rounded border-gray-300 focus:ring-emerald-500'
                                        }
                                    })
                                }}

                            </div>

                        </div>

                        <div class="mt-2 text-sm text-red-500">
                            {{ form_errors(form.roles) }}
                        </div>

                    </div>

                    <!-- PASSWORD -->
                    <div>

                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                            Mot de passe
                        </label>

                        <div class="relative">

                            {{
                                form_widget(form.password, {
                                    attr: {
                                        class: 'w-full rounded-2xl border border-gray-300 px-5 py-3 pr-14 focus:ring-2 focus:ring-emerald-500 focus:outline-none bg-gray-50',
                                        id: 'passwordInput'
                                    }
                                })
                            }}

                            <!-- EYE BUTTON -->
                            <button 
                                type="button"
                                onclick="togglePassword()"
                                class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 hover:text-emerald-700 transition"
                            >
                                👁️
                            </button>

                        </div>

                        <div class="mt-2 text-sm text-red-500">
                            {{ form_errors(form.password) }}
                        </div>

                    </div>

                </div>

                <!-- BUTTONS -->
                <div class="flex flex-col sm:flex-row gap-4 mt-10">

                    <button 
                        type="submit"
                        class="flex-1 bg-gradient-to-r from-emerald-700 to-emerald-600 hover:from-emerald-800 hover:to-emerald-700 text-white font-semibold py-3.5 rounded-2xl shadow-lg transition duration-300 hover:-translate-y-1"
                    >
                        Créer l'utilisateur
                    </button>

                    <a 
                        href="{{ path('app_user_index') }}"
                        class="flex-1 text-center bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-3.5 rounded-2xl transition duration-300"
                    >
                        Retour à la liste
                    </a>

                </div>

                {{ form_end(form) }}

            </div>

        </div>

    </div>

</section>

<script>

    function togglePassword() {

        const passwordInput = document.getElementById('passwordInput');

        if (passwordInput.type === 'password') {

            passwordInput.type = 'text';

        } else {

            passwordInput.type = 'password';

        }
    }

</script>

{% endblock %}