{% extends 'base.html.twig' %}

{% block title %}Modifier Média{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-100 py-10 px-4">

    <div class="max-w-3xl mx-auto bg-white shadow-lg rounded-2xl p-8">

        <!-- Titre -->
        <h1 class="text-3xl font-bold text-gray-800 mb-6 text-center">
            ✏️ Modifier un média
        </h1>

        <!-- Formulaire -->
        <div class="mb-8">
            {{ include('media/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
        </div>

        <!-- Actions -->
        <div class="flex flex-col md:flex-row justify-between items-center gap-4 mt-6">

            <!-- Retour -->
            <a href="{{ path('app_media_index') }}"
               class="text-gray-600 hover:text-gray-900 underline transition">
                ← Retour à la liste
            </a>

            <!-- Supprimer -->
            <div>
                {{ include('media/_delete_form.html.twig') }}
            </div>

        </div>

    </div>

</div>
{% endblock %}