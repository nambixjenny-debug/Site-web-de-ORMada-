{% extends 'base.html.twig' %}

{% block title %}Media index{% endblock %}

{% block body %}

<div class="h-screen overflow-hidden bg-gradient-to-br from-slate-100 via-emerald-50 to-white flex flex-col">

    <!-- HEADER -->
    <section class="shrink-0 bg-gradient-to-r from-emerald-800 via-emerald-700 to-emerald-600 shadow-2xl">

        <div class="max-w-7xl mx-auto px-6 py-4 flex flex-col md:flex-row md:items-center md:justify-between gap-2">

            <div>

                <h1 class="text-4xl font-bold text-white">
                    Gestion des medias
                </h1>

                <p class="text-emerald-100 mt-2 text-sm tracking-wide">
                    Administration ORMada
                </p>

            </div>

            <a href="{{ path('app_media_new') }}"
               class="inline-flex items-center justify-center gap-1 px-6 py-2 bg-emerald-500 hover:bg-emerald-600 rounded-2xl  text-white font-semibold shadow-lg hover:shadow-2xl hover:-translate-y-1 transition duration-300">

                <span class="text-xl">+</span>
                <span>Créer un media</span>

            </a>

        </div>

    </section>


    <!-- Table Container -->
    <div class="bg-white shadow-lg rounded-xl overflow-hidden mt-3 border border-green-100">

        <table class="min-w-full divide-y divide-gray-200">

            <thead class="bg-gradient-to-r from-green-800 via-emerald-700 to-teal-700 text-white">
                <tr>
                    <th class="px-6 py-4 text-left text-sm font-semibold ">ID</th>
                    <th class="px-6 py-4 text-left text-sm font-semibold ">IMAGE</th>
                    <th class="px-6 py-4 text-left text-sm font-semibold ">Nom du fichier</th>
                    <th class="px-6 py-4 text-left text-sm font-semibold ">Type</th>
                    <th class="px-6 py-4 text-left text-sm font-semibold ">Chemin</th>
                    <th class="px-6 py-4 text-left text-sm font-semibold ">Upload At</th>
                    <th class="px-6 py-4 text-left text-sm font-semibold ">Actions</th>
                </tr>
            </thead>

            <tbody class="divide-y divide-gray-100">

            {% for medium in media %}
                <tr class="hover:bg-gray-50 transition">

                    <td class="px-6 py-4 text-gray-700">
                        {{ medium.id }}
                    </td>
                    <td>
                        <img src="{{ medium.chemindufichier }}"class="h-20 w-20 object-cover rounded">
                        
                    </td>
            
                    <td class="px-6 py-4 font-medium text-gray-800">
                        {{ medium.nomdufichier }}
                    </td>

                    <td class="px-6 py-4">
                        <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm">
                            {{ medium.typedufichier }}
                        </span>
                    </td>

                    <td class="px-6 py-4 text-gray-500 truncate max-w-xs">
                        {{ medium.chemindufichier }}
                    </td>

                    <td class="px-6 py-4 text-gray-600">
                        {{ medium.uploadat ? medium.uploadat|date('Y-m-d H:i:s') : '' }}
                    </td>

                    <td class="px-6 py-4 flex gap-2">

                        <a href="{{ path('app_media_show', {'id': medium.id}) }}"
                           class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg text-sm transition">
                            Voir
                        </a>

                        <a href="{{ path('app_media_edit', {'id': medium.id}) }}"
                           class="bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded-lg text-sm transition">
                            Modifier
                        </a>

                    </td>

                </tr>

            {% else %}
                <tr>
                    <td colspan="6" class="text-center py-8 text-gray-500">
                        Aucun média trouvé.
                    </td>
                </tr>
            {% endfor %}

            </tbody>

        </table>

    </div>

</div>

{% endblock %}