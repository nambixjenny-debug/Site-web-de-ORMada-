{{ form_start(form, {'attr': { 'class': 'space-y-6','enctype': 'multipart/form-data'}})}}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        {% for field in form %}
            <div>
                {{ form_label(field, null, {
                    'label_attr': {
                        'class': 'block text-sm font-medium text-gray-700 mb-2'
                    }
                }) }}

                {{ form_widget(field, {
                    'attr': {
                        'class': 'w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-green-500 focus:outline-none'
                    }
                }) }}

                {{ form_errors(field) }}
            </div>
        {% endfor %}

    </div>

    <button class="bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded-lg shadow transition">
        {{ button_label|default('Enregistrer') }}
    </button>

{{ form_end(form) }}