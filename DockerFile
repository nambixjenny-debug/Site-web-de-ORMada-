FROM php:8.3-apache

RUN apt-get update && apt-get install -y \
    git unzip zip libzip-dev libicu-dev libonig-dev libpq-dev \
    && docker-php-ext-install pdo pdo_mysql pdo_pgsql intl zip opcache

RUN a2enmod rewrite

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

WORKDIR /var/www/html

COPY . .

# 🔥 Installer dépendances proprement (SANS casser Symfony)
RUN composer install --no-dev --optimize-autoloader

# 🔥 Créer structure Symfony obligatoire
RUN mkdir -p var/cache var/log

# 🔥 Permissions correctes
RUN chown -R www-data:www-data /var/www/html

EXPOSE 80

CMD ["apache2-foreground"]